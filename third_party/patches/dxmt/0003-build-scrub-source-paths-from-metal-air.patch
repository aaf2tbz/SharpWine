+python3 = find_program('python3')
+metal_air_wrapper = join_paths(
+  meson.project_source_root(),
+  'build-aux/canonicalize_metal_air.py',
+)
+native_llvm_path = get_option('native_llvm_path')
 
-metalir_generator = generator(xcrun,
+metalir_generator = generator(python3,
   output    : [ '@BASENAME@.air'],
-  arguments : [ '-sdk', 'macosx', 'metal', '-o', '@OUTPUT@', '-c', '@INPUT@', '@EXTRA_ARGS@'],
+  arguments : [ metal_air_wrapper,
+                '--xcrun', xcrun.full_path(),
+                '--llvm-dis', '@0@/bin/llvm-dis'.format(native_llvm_path),
+                '--llvm-as', '@0@/bin/llvm-as'.format(native_llvm_path),
+                '--source-root', meson.project_source_root(),
+                '--output', '@OUTPUT@',
+                '--input', '@INPUT@',
+                '--', '@EXTRA_ARGS@' ],
 )
 
 metallib_generator = generator(xcrun,
