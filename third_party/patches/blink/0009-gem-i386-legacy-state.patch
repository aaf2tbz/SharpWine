@@ -0,0 +1,354 @@
+/*-*- mode:c;indent-tabs-mode:nil;c-basic-offset:2;tab-width:8;coding:utf-8 -*-│
+│ Copyright 2026 MetalSharp contributors                                      │
+│ SPDX-License-Identifier: ISC                                                │
+╚─────────────────────────────────────────────────────────────────────────────*/
+#include <math.h>
+#include <string.h>
+
+#include "blink/endian.h"
+#include "blink/flags.h"
+#include "blink/machine.h"
+#include "blink/modrm.h"
+#include "blink/rde.h"
+#include "blink/x86.h"
+
+static u8 *Dst(P) { return XmmRexrReg(m, rde); }
+static const u8 *Src(P) { return GetModrmRegisterXmmPointerRead16(A); }
+
+static i64 SignedElement(const u8 *p, unsigned size) {
+  if (size == 1) return (i8)Get8(p);
+  return (i16)Get16(p);
+}
+
+static u64 UnsignedElement(const u8 *p, unsigned size) {
+  return size == 1 ? Get8(p) : Get16(p);
+}
+
+static void PutElement(u8 *p, unsigned size, u64 value) {
+  if (size == 1) Put8(p, value);
+  else if (size == 2) Put16(p, value);
+  else if (size == 4) Put32(p, value);
+  else Put64(p, value);
+}
+
+static void Blend(P, unsigned size, unsigned mask) {
+  u8 *d = Dst(A);
+  const u8 *s = Src(A);
+  unsigned i, count = 16 / size;
+  for (i = 0; i < count; ++i)
+    if (mask & (1u << i)) memcpy(d + i * size, s + i * size, size);
+}
+
+static void BlendVariable(P, unsigned size) {
+  u8 *d = Dst(A);
+  const u8 *s = Src(A);
+  u8 mask[16];
+  unsigned i, count = 16 / size;
+  memcpy(mask, m->xmm[0], sizeof(mask));
+  for (i = 0; i < count; ++i)
+    if (mask[i * size + size - 1] & 0x80)
+      memcpy(d + i * size, s + i * size, size);
+}
+
+static double RoundValue(double x, unsigned mode) {
+  double lo, fraction;
+  switch (mode & 3) {
+    case 0:
+      if (!isfinite(x) || fabs(x) >= 0x1p52) return x;
+      lo = floor(x);
+      fraction = x - lo;
+      if (fraction > .5 || (fraction == .5 && fmod(fabs(lo), 2) == 1)) lo += 1;
+      return lo;
+    case 1: return floor(x);
+    case 2: return ceil(x);
+    default: return trunc(x);
+  }
+}
+
+static unsigned RoundMode(P) {
+  return (uimm0 & 4) ? ((m->mxcsr >> 13) & 3) : (uimm0 & 3);
+}
+
+static void RoundPacked(P, bool doubles) {
+  u8 *d = Dst(A);
+  const u8 *s = Src(A);
+  unsigned i, n = doubles ? 2 : 4, mode = RoundMode(A);
+  for (i = 0; i < n; ++i) {
+    if (doubles) {
+      double x;
+      memcpy(&x, s + 8 * i, 8);
+      x = RoundValue(x, mode);
+      memcpy(d + 8 * i, &x, 8);
+    } else {
+      float x;
+      memcpy(&x, s + 4 * i, 4);
+      x = (float)RoundValue(x, mode);
+      memcpy(d + 4 * i, &x, 4);
+    }
+  }
+}
+
+static void RoundScalar(P, bool doubles) {
+  u8 *d = Dst(A);
+  const u8 *s = Src(A);
+  unsigned mode = RoundMode(A);
+  if (doubles) {
+    double x;
+    memcpy(&x, s, 8);
+    x = RoundValue(x, mode);
+    memcpy(d, &x, 8);
+  } else {
+    float x;
+    memcpy(&x, s, 4);
+    x = (float)RoundValue(x, mode);
+    memcpy(d, &x, 4);
+  }
+}
+
+static void Extend(P, unsigned in_size, unsigned out_size, bool sign) {
+  u8 *d = Dst(A);
+  const u8 *s = Src(A);
+  unsigned i, n = 16 / out_size;
+  u8 result[16] = {0};
+  for (i = 0; i < n; ++i) {
+    u64 value = sign ? (u64)SignedElement(s + i * in_size, in_size)
+                     : UnsignedElement(s + i * in_size, in_size);
+    PutElement(result + i * out_size, out_size, value);
+  }
+  memcpy(d, result, 16);
+}
+
+static void PmulDq(P) {
+  u8 *d = Dst(A);
+  const u8 *s = Src(A);
+  i64 a0 = (i32)Get32(d), a1 = (i32)Get32(d + 8);
+  i64 b0 = (i32)Get32(s), b1 = (i32)Get32(s + 8);
+  Put64(d, a0 * b0);
+  Put64(d + 8, a1 * b1);
+}
+
+static void Packusdw(P) {
+  u8 result[16], old[16];
+  u8 *d = Dst(A);
+  const u8 *s = Src(A);
+  unsigned i;
+  memcpy(old, d, 16);
+  for (i = 0; i < 8; ++i) {
+    i32 x = (i32)Get32(i < 4 ? old + 4 * i : s + 4 * (i - 4));
+    Put16(result + 2 * i, x < 0 ? 0 : x > 65535 ? 65535 : x);
+  }
+  memcpy(d, result, 16);
+}
+
+static void CompareQword(P) {
+  u8 *d = Dst(A);
+  const u8 *s = Src(A);
+  Put64(d, (i64)Get64(d) > (i64)Get64(s) ? UINT64_MAX : 0);
+  Put64(d + 8, (i64)Get64(d + 8) > (i64)Get64(s + 8) ? UINT64_MAX : 0);
+}
+
+static void Ptest(P) {
+  const u8 *a = Dst(A), *b = Src(A);
+  u64 av = Get64(a) | Get64(a + 8);
+  u64 andv = (Get64(a) & Get64(b)) | (Get64(a + 8) & Get64(b + 8));
+  u64 andnv = (~Get64(a) & Get64(b)) | (~Get64(a + 8) & Get64(b + 8));
+  (void)av;
+  m->flags = SetFlag(m->flags, FLAGS_ZF, !andv);
+  m->flags = SetFlag(m->flags, FLAGS_CF, !andnv);
+  m->flags = SetFlag(m->flags, FLAGS_AF, false);
+  m->flags = SetFlag(m->flags, FLAGS_OF, false);
+  m->flags = SetFlag(m->flags, FLAGS_PF, false);
+  m->flags = SetFlag(m->flags, FLAGS_SF, false);
+}
+
+static void Phminposuw(P) {
+  const u8 *s = Src(A);
+  u8 result[16] = {0};
+  unsigned i, index = 0;
+  u16 value = Get16(s);
+  for (i = 1; i < 8; ++i)
+    if (Get16(s + 2 * i) < value) value = Get16(s + 2 * (index = i));
+  Put16(result, value);
+  Put16(result + 2, index);
+  memcpy(Dst(A), result, 16);
+}
+
+static void Dot(P, bool doubles) {
+  u8 *d = Dst(A);
+  const u8 *s = Src(A);
+  unsigned i, n = doubles ? 2 : 4;
+  double sum = 0;
+  if (doubles) {
+    double a, b;
+    for (i = 0; i < n; ++i) if (uimm0 & (1u << (4 + i))) {
+      memcpy(&a, d + 8 * i, 8); memcpy(&b, s + 8 * i, 8); sum += a * b;
+    }
+    for (i = 0; i < n; ++i) { double x = (uimm0 & (1u << i)) ? sum : 0; memcpy(d + 8 * i, &x, 8); }
+  } else {
+    float a, b, fsum;
+    for (i = 0; i < n; ++i) if (uimm0 & (1u << (4 + i))) {
+      memcpy(&a, d + 4 * i, 4); memcpy(&b, s + 4 * i, 4); sum += (double)a * b;
+    }
+    fsum = (float)sum;
+    for (i = 0; i < n; ++i) { float x = (uimm0 & (1u << i)) ? fsum : 0; memcpy(d + 4 * i, &x, 4); }
+  }
+}
+
+static void Mpsadbw(P) {
+  u8 old[16], result[16];
+  u8 *d = Dst(A);
+  const u8 *s = Src(A);
+  unsigned i, j, aoff = ((uimm0 >> 2) & 1) * 4, boff = (uimm0 & 3) * 4;
+  memcpy(old, d, 16);
+  for (i = 0; i < 8; ++i) {
+    unsigned sum = 0;
+    for (j = 0; j < 4; ++j) {
+      int x = old[aoff + i + j] - s[boff + j];
+      sum += x < 0 ? -x : x;
+    }
+    Put16(result + 2 * i, sum);
+  }
+  memcpy(d, result, 16);
+}
+
+static unsigned StringLength(const u8 *p, unsigned count, unsigned size) {
+  unsigned i;
+  for (i = 0; i < count; ++i)
+    if (size == 1 ? !p[i] : !Get16(p + 2 * i)) return i;
+  return count;
+}
+
+static bool StringEqual(const u8 *a, const u8 *b, unsigned i, unsigned j,
+                        unsigned size, bool sign) {
+  return sign ? SignedElement(a + i * size, size) == SignedElement(b + j * size, size)
+              : UnsignedElement(a + i * size, size) == UnsignedElement(b + j * size, size);
+}
+
+static void PackedStringCompare(P, bool explicit_length, bool return_mask) {
+  u8 *a = Dst(A);
+  const u8 *b = Src(A);
+  unsigned mode = uimm0 & 3, size = (mode & 1) ? 2 : 1;
+  bool sign = (mode & 2) != 0;
+  unsigned max = 16 / size, aggregation = (uimm0 >> 2) & 3;
+  unsigned la, lb, i, j, bits = 0, valid_b;
+  if (explicit_length) {
+    i32 xa = (i32)Get32(m->ax), xb = (i32)Get32(m->dx);
+    la = (unsigned)(xa < 0 ? -(i64)xa : xa); if (la > max) la = max;
+    lb = (unsigned)(xb < 0 ? -(i64)xb : xb); if (lb > max) lb = max;
+  } else {
+    la = StringLength(a, max, size);
+    lb = StringLength(b, max, size);
+  }
+  valid_b = lb == 32 ? UINT32_MAX : ((1u << lb) - 1);
+  for (j = 0; j < max; ++j) {
+    bool value = false;
+    if (aggregation == 0) {
+      for (i = 0; i < la && j < lb; ++i) value |= StringEqual(a, b, i, j, size, sign);
+    } else if (aggregation == 1) {
+      for (i = 0; i + 1 < la && j < lb; i += 2) {
+        i64 x = sign ? SignedElement(b + j * size, size) : (i64)UnsignedElement(b + j * size, size);
+        i64 lo = sign ? SignedElement(a + i * size, size) : (i64)UnsignedElement(a + i * size, size);
+        i64 hi = sign ? SignedElement(a + (i + 1) * size, size) : (i64)UnsignedElement(a + (i + 1) * size, size);
+        value |= lo <= x && x <= hi;
+      }
+    } else if (aggregation == 2) {
+      value = (j < la && j < lb) ? StringEqual(a, b, j, j, size, sign)
+                                 : (j >= la && j >= lb);
+    } else if (j < lb) {
+      value = true;
+      for (i = 0; i < la; ++i)
+        if (j + i >= lb || !StringEqual(a, b, i, j + i, size, sign)) value = false;
+    }
+    if (value) bits |= 1u << j;
+  }
+  switch ((uimm0 >> 4) & 3) {
+    case 1: bits = (~bits) & ((1u << max) - 1); break;
+    case 2: bits &= valid_b; break;
+    case 3: bits = (~bits) & valid_b; break;
+  }
+  m->flags = SetFlag(m->flags, FLAGS_CF, bits != 0);
+  m->flags = SetFlag(m->flags, FLAGS_ZF, lb < max);
+  m->flags = SetFlag(m->flags, FLAGS_SF, la < max);
+  m->flags = SetFlag(m->flags, FLAGS_OF, bits & 1);
+  m->flags = SetFlag(m->flags, FLAGS_AF, false);
+  m->flags = SetFlag(m->flags, FLAGS_PF, false);
+  if (return_mask) {
+    memset(m->xmm[0], 0, 16);
+    if (uimm0 & 0x40) {
+      for (i = 0; i < max; ++i) if (bits & (1u << i))
+        PutElement(m->xmm[0] + i * size, size, size == 1 ? 0xff : 0xffff);
+    } else {
+      Put16(m->xmm[0], bits);
+    }
+  } else {
+    unsigned index = max;
+    if (bits) {
+      if (uimm0 & 0x40) {
+        for (i = max; i-- > 0;)
+          if (bits & (1u << i)) { index = i; break; }
+      } else {
+        for (i = 0; i < max; ++i)
+          if (bits & (1u << i)) { index = i; break; }
+      }
+    }
+    Put32(m->cx, index);
+  }
+}
+
+void OpSse4(P) {
+  u8 *d;
+  const u8 *s;
+  unsigned i, op = Mopcode(rde);
+  if (!Osz(rde)) { OpUdImpl(m); return; }
+  switch (op) {
+    case 0x210: BlendVariable(A, 1); break;
+    case 0x214: BlendVariable(A, 4); break;
+    case 0x215: BlendVariable(A, 8); break;
+    case 0x217: Ptest(A); break;
+    case 0x220: Extend(A, 1, 2, true); break;
+    case 0x221: Extend(A, 1, 4, true); break;
+    case 0x222: Extend(A, 1, 8, true); break;
+    case 0x223: Extend(A, 2, 4, true); break;
+    case 0x224: Extend(A, 2, 8, true); break;
+    case 0x225: Extend(A, 4, 8, true); break;
+    case 0x228: PmulDq(A); break;
+    case 0x229:
+      d = Dst(A); s = Src(A); Put64(d, Get64(d) == Get64(s) ? UINT64_MAX : 0);
+      Put64(d + 8, Get64(d + 8) == Get64(s + 8) ? UINT64_MAX : 0); break;
+    case 0x22a: memcpy(Dst(A), Src(A), 16); break;
+    case 0x22b: Packusdw(A); break;
+    case 0x230: Extend(A, 1, 2, false); break;
+    case 0x231: Extend(A, 1, 4, false); break;
+    case 0x232: Extend(A, 1, 8, false); break;
+    case 0x233: Extend(A, 2, 4, false); break;
+    case 0x234: Extend(A, 2, 8, false); break;
+    case 0x235: Extend(A, 4, 8, false); break;
+    case 0x237: CompareQword(A); break;
+    case 0x241: Phminposuw(A); break;
+    case 0x308: RoundPacked(A, false); break;
+    case 0x309: RoundPacked(A, true); break;
+    case 0x30a: RoundScalar(A, false); break;
+    case 0x30b: RoundScalar(A, true); break;
+    case 0x30c: Blend(A, 4, uimm0); break;
+    case 0x30d: Blend(A, 8, uimm0); break;
+    case 0x30e: Blend(A, 2, uimm0); break;
+    case 0x314: Put8(GetModrmRegisterBytePointerWrite1(A), Dst(A)[uimm0 & 15]); break;
+    case 0x315: Put16(GetModrmRegisterWordPointerWrite2(A), Get16(Dst(A) + 2 * (uimm0 & 7))); break;
+    case 0x316: Put32(GetModrmRegisterWordPointerWrite4(A), Get32(Dst(A) + 4 * (uimm0 & 3))); break;
+    case 0x317: Put32(GetModrmRegisterWordPointerWrite4(A), Get32(Dst(A) + 4 * (uimm0 & 3))); break;
+    case 0x320: d = Dst(A); Put8(d + (uimm0 & 15), Get8(GetModrmRegisterBytePointerRead1(A))); break;
+    case 0x321:
+      d = Dst(A); s = Src(A); { u8 old[16]; memcpy(old, d, 16); memcpy(d, old, 16);
+      memcpy(d + 4 * ((uimm0 >> 4) & 3), s + 4 * ((uimm0 >> 6) & 3), 4);
+      for (i = 0; i < 4; ++i) if (uimm0 & (1u << i)) Put32(d + 4 * i, 0); } break;
+    case 0x322: d = Dst(A); Put32(d + 4 * (uimm0 & 3), Get32(GetModrmRegisterWordPointerRead4(A))); break;
+    case 0x340: Dot(A, false); break;
+    case 0x341: Dot(A, true); break;
+    case 0x342: Mpsadbw(A); break;
+    case 0x360: PackedStringCompare(A, true, true); break;
+    case 0x361: PackedStringCompare(A, true, false); break;
+    case 0x362: PackedStringCompare(A, false, true); break;
+    case 0x363: PackedStringCompare(A, false, false); break;
+    default: OpUdImpl(m); break;
+  }
+}
