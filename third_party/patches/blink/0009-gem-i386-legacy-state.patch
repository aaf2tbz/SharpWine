+#define GEM_SEG_PRESENT     0x01u
+#define GEM_SEG_WRITABLE    0x02u
+#define GEM_SEG_EXECUTABLE  0x04u
+#define GEM_SEG_EXPAND_DOWN 0x08u
+#define GEM_SEG_DEFAULT_32  0x10u
+
+void CheckLegacySegmentAccess(struct Machine *m, const struct DescriptorCache *s,
+                              u64 offset, u64 size, bool write, bool execute) {
+  u64 end, upper, fault;
+  if (!m->gemembed || m->mode.omode == XED_MODE_LONG || !s->attributes) return;
+  if (!(s->attributes & GEM_SEG_PRESENT)) ThrowSegmentationFault(m, s->base + offset);
+  if (write && !(s->attributes & GEM_SEG_WRITABLE))
+    ThrowSegmentationFault(m, s->base + offset);
+  if (execute && !(s->attributes & GEM_SEG_EXECUTABLE))
+    ThrowSegmentationFault(m, s->base + offset);
+  upper = (s->attributes & GEM_SEG_DEFAULT_32) ? UINT32_MAX : UINT16_MAX;
+  if (!size || __builtin_add_overflow(offset, size - 1, &end) || end > upper)
+    ThrowSegmentationFault(m, s->base + offset);
+  if (s->attributes & GEM_SEG_EXPAND_DOWN) {
+    if (offset <= s->limit) ThrowSegmentationFault(m, s->base + offset);
+  } else if (end > s->limit) {
+    fault = offset > s->limit ? offset : (u64)s->limit + 1;
+    ThrowSegmentationFault(m, s->base + fault);
+  }
+}
