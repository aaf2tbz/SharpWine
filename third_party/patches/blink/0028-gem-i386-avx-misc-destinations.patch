     if (pp == 0) {
       return op == 0x10 || op == 0x12 || op == 0x14 || op == 0x15 ||
-             op == 0x28 || (op >= 0x51 && op <= 0x5f) || op == 0xc2 ||
+             op == 0x16 || op == 0x28 || (op >= 0x51 && op <= 0x5f) || op == 0xc2 ||
              op == 0xc6;
     }
     if (pp == 1) {
       return op == 0x10 || op == 0x12 || op == 0x14 || op == 0x15 ||
-             op == 0x28 || (op >= 0x51 && op <= 0x6d) || op == 0x6f ||
+             op == 0x16 || op == 0x28 || (op >= 0x51 && op <= 0x6d) || op == 0x6f ||
              op == 0x70 || (op >= 0x74 && op <= 0x76) || op == 0x7c ||
              op == 0x7d || op == 0xc2 || op == 0xc6 ||
              (op >= 0xd0 && op <= 0xd5) || (op >= 0xd8 && op <= 0xef) ||
@@ -91,6 +91,38 @@
   return false;
 }
 
+static bool SupportsMisc(u64 rde) {
+  unsigned map = Opmap(rde);
+  unsigned op = Opcode(rde);
+  unsigned pp = Prefix(rde);
+  if (map == XED_ILD_MAP1) {
+    if ((op == 0x2e || op == 0x2f) && pp <= 1)
+      return !Ymm(rde) && Vreg(rde) == 0;
+    if ((op == 0x2c || op == 0x2d) && pp >= 2)
+      return !Ymm(rde) && Vreg(rde) == 0;
+    if (op == 0x50 && pp <= 1) return Vreg(rde) == 0;
+    if (op == 0x6e && pp == 1)
+      return !Ymm(rde) && !Rexw(rde) && Vreg(rde) == 0;
+    if (op == 0x7e && !Ymm(rde) && Vreg(rde) == 0)
+      return (pp == 1 && !Rexw(rde)) || pp == 2;
+    if (op == 0xae && pp == 0)
+      return !Ymm(rde) && Vreg(rde) == 0 && !IsModrmRegister(rde) &&
+             (ModrmReg(rde) == 2 || ModrmReg(rde) == 3);
+    if (op == 0xc4 && pp == 1) return !Ymm(rde);
+    if (op == 0xc5 && pp == 1) return !Ymm(rde) && Vreg(rde) == 0;
+    if (op == 0xd6 && pp == 1)
+      return !Ymm(rde) && Vreg(rde) == 0 && IsModrmRegister(rde);
+    if (op == 0xd7 && pp == 1) return !Ymm(rde) && Vreg(rde) == 0;
+    return false;
+  }
+  if (map != XED_ILD_MAP3 || pp != 1 || Ymm(rde)) return false;
+  if (op >= 0x14 && op <= 0x17)
+    return Vreg(rde) == 0 && (op != 0x16 || !Rexw(rde));
+  if (op == 0x20 || op == 0x22) return op != 0x22 || !Rexw(rde);
+  if (op >= 0x60 && op <= 0x63) return Vreg(rde) == 0;
+  return false;
+}
+
 static bool SupportsStore(u64 rde) {
