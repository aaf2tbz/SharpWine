+}
+
+static u64 ReadScalarOperand(P, size_t size) {
+  const u8 *source;
+  if (IsModrmRegister(rde)) source = RegRexbRm(m, rde);
+  else source = ComputeReserveAddressRead(A, size);
+  if (size == 1) return Get8(source);
+  if (size == 2) return Get16(source);
+  if (size == 4) return Get32(source);
+  return Get64(source);
+}
+
+static void WriteScalarDestination(P, size_t size, u64 value) {
+  u8 *destination;
+  if (IsModrmRegister(rde)) {
+    Put32(RegRexbRm(m, rde), value);
+    return;
+  }
+  destination = ComputeReserveAddressWrite(A, size);
+  if (size == 1) Put8(destination, value);
+  else if (size == 2) Put16(destination, value);
+  else if (size == 4) Put32(destination, value);
+  else Put64(destination, value);
+  if (m->stashaddr) CommitStash(m);
+}
+
+static void RunAvxMovMask(P) {
+  u8 source[32];
+  size_t size;
+  unsigned i, result, stride;
+  size = Ymm(rde) ? 32 : 16;
+  stride = Prefix(rde) == 0 ? 4 : 8;
+  ReadOperandVector(A, size, source);
+  result = 0;
+  for (i = 0; i < size / stride; ++i) {
+    result |= (unsigned)(source[stride * i + stride - 1] >> 7) << i;
+  }
+  Put32(RegRexrReg(m, rde), result);
+}
+
+static void RunAvxPmovmskb(P) {
+  u8 source[32];
+  unsigned i, result;
+  ReadOperandVector(A, 16, source);
+  result = 0;
+  for (i = 0; i < 16; ++i) result |= (unsigned)(source[i] >> 7) << i;
+  Put32(RegRexrReg(m, rde), result);
+}
+
+static void RunAvxMoveScalar(P) {
+  u8 result[32] = {0};
+  unsigned op = Opcode(rde);
+  if (op == 0x6e) {
+    Put32(result, ReadScalarOperand(A, 4));
+    WriteRegisterVector(m, RexrReg(rde), 16, result);
+  } else if (op == 0x7e && Prefix(rde) == 2) {
+    Put64(result, ReadScalarOperand(A, 8));
+    WriteRegisterVector(m, RexrReg(rde), 16, result);
+  } else if (op == 0x7e) {
+    WriteScalarDestination(A, 4, Get32(m->xmm[RexrReg(rde)]));
+  } else {
+    ReadRegisterVector(m, RexrReg(rde), 16, result);
+    WriteRegisterVector(m, RexbRm(rde), 16, result);
   }
 }
 
+static void RunAvxExtractScalar(P) {
+  size_t size;
+  u64 value;
+  unsigned map = Opmap(rde);
+  unsigned op = Opcode(rde);
+  if (map == XED_ILD_MAP1) {
+    value = Get16(m->xmm[RexbRm(rde)] + 2 * (uimm0 & 7));
+    Put32(RegRexrReg(m, rde), value);
+    return;
+  }
+  size = op == 0x14 ? 1 : op == 0x15 ? 2 : 4;
+  if (size == 1) value = Get8(m->xmm[RexrReg(rde)] + (uimm0 & 15));
+  else if (size == 2) value = Get16(m->xmm[RexrReg(rde)] + 2 * (uimm0 & 7));
+  else value = Get32(m->xmm[RexrReg(rde)] + 4 * (uimm0 & 3));
+  WriteScalarDestination(A, size, value);
+}
+
+static void RunAvxInsertScalar(P) {
+  u8 result[32];
+  size_t size;
+  unsigned map = Opmap(rde);
+  unsigned op = Opcode(rde);
+  size = map == XED_ILD_MAP1 ? 2 : op == 0x20 ? 1 : 4;
+  ReadRegisterVector(m, Vreg(rde), 16, result);
+  if (size == 1) Put8(result + (uimm0 & 15), ReadScalarOperand(A, 1));
+  else if (size == 2) Put16(result + 2 * (uimm0 & 7), ReadScalarOperand(A, 2));
+  else Put32(result + 4 * (uimm0 & 3), ReadScalarOperand(A, 4));
+  WriteRegisterVector(m, RexrReg(rde), 16, result);
+}
+
+static void RunAvxDirectLegacy(P) {
+  GetOp(Mopcode(rde))(A);
+  if (Opmap(rde) == XED_ILD_MAP3 &&
+      (Opcode(rde) == 0x60 || Opcode(rde) == 0x62)) {
+    memset(m->ymm_upper[0], 0, 16);
+  }
+  if (m->stashaddr) CommitStash(m);
+}
+
+static void RunAvxMisc(P) {
+  unsigned map = Opmap(rde);
+  unsigned op = Opcode(rde);
+  if (map == XED_ILD_MAP1 && op == 0x50) RunAvxMovMask(A);
+  else if (map == XED_ILD_MAP1 && op == 0xd7) RunAvxPmovmskb(A);
+  else if (map == XED_ILD_MAP1 && (op == 0x6e || op == 0x7e || op == 0xd6))
+    RunAvxMoveScalar(A);
+  else if ((map == XED_ILD_MAP1 && op == 0xc5) ||
+           (map == XED_ILD_MAP3 && op >= 0x14 && op <= 0x17))
+    RunAvxExtractScalar(A);
+  else if ((map == XED_ILD_MAP1 && op == 0xc4) ||
+           (map == XED_ILD_MAP3 && (op == 0x20 || op == 0x22)))
+    RunAvxInsertScalar(A);
+  else
+    RunAvxDirectLegacy(A);
+}
+
 static void RunAvxFoundation(P) {
   u8 initial[2][16], source[2][16], result[2][16];
   const u8 *memory_source;
