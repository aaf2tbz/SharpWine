diff --git a/blink/machine.c b/blink/machine.c
index ad309eb..cd1e92b 100644
--- a/blink/machine.c
+++ b/blink/machine.c
@@ -2092,0 +2093,7 @@ nexgen32e_f GetOp(long op) {
+bool GemIsAllowedHandler(nexgen32e_f handler) {
+  return handler == OpNop || handler == OpMovZvqpIvqp ||
+         handler == OpMovEvqpGvqp || handler == OpMovGvqpEvqp ||
+         handler == OpBsuwiImm || handler == OpAlui || handler == OpJcc || handler == OpJmp ||
+         handler == OpRet;
+}
+
diff --git a/blink/throw.c b/blink/throw.c
index a2f8a88..5943ee3 100644
--- a/blink/throw.c
+++ b/blink/throw.c
@@ -64,0 +65,6 @@ void HaltMachine(struct Machine *m, int code) {
+  if (m->gemembed) {
+    m->trapno = code;
+    if (!m->faultaddr) m->faultaddr = m->ip;
+    unassert(m->canhalt);
+    siglongjmp(m->onhalt, code);
+  }
