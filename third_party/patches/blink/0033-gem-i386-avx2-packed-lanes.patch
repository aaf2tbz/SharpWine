+static bool IsAvxSharedCountShift(u64 rde) {
+  unsigned op = Opcode(rde);
+  return Ymm(rde) && Opmap(rde) == XED_ILD_MAP1 && Prefix(rde) == 1 &&
+         ((op >= 0xd1 && op <= 0xd3) || op == 0xe1 || op == 0xe2 ||
+          (op >= 0xf1 && op <= 0xf3));
+}
+
+static void RunAvxSharedCountShift(P) {
+  u8 data[32], operand[32], result[32] = {0};
+  u64 count, value;
+  size_t i, width;
+  unsigned op = Opcode(rde);
+  width = (op & 3) == 1 ? 2 : (op & 3) == 2 ? 4 : 8;
+  ReadRegisterVector(m, Vreg(rde), 32, data);
+  ReadOperandVector(A, 16, operand);
+  count = Get64(operand);
+  for (i = 0; i < 32; i += width) {
+    if (width == 2)
+      value = Get16(data + i);
+    else if (width == 4)
+      value = Get32(data + i);
+    else
+      value = Get64(data + i);
+    if ((op & 0xf0) == 0xf0) {
+      value = count < 8 * width ? value << count : 0;
+    } else if ((op & 0xf0) == 0xe0) {
+      if (width == 2)
+        value = (i16)value >> (count < 16 ? count : 15);
+      else
+        value = (i32)value >> (count < 32 ? count : 31);
+    } else {
+      value = count < 8 * width ? value >> count : 0;
+    }
+    if (width == 2)
+      Put16(result + i, value);
+    else if (width == 4)
+      Put32(result + i, value);
+    else
+      Put64(result + i, value);
+  }
+  memcpy(m->xmm[RexrReg(rde)], result, 16);
+  memcpy(m->ymm_upper[RexrReg(rde)], result + 16, 16);
+}
