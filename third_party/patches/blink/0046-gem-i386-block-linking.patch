+static size_t block_slot(uint64_t pc) {
+  return (size_t)((pc ^ (pc >> 8) ^ (pc >> 16)) &
+                  (BLINK_GEM_BLOCK_CACHE_ENTRIES - 1u));
+}
+static struct blink_gem_block_entry* block_lookup(
+    struct blink_gem_machine* g, uint64_t pc) {
+  struct blink_gem_block_entry* block;
+  ++g->block_lookups;
+  block = g->blocks + block_slot(pc);
+  if (!block->valid || block->pc != pc) return 0;
+  ++g->block_cache_hits;
+  return block;
+}
+static struct blink_gem_block_entry* block_linked_successor(
+    struct blink_gem_machine* g, struct blink_gem_block_entry* previous,
+    uint64_t pc) {
+  struct blink_gem_block_entry* block;
+  if (!previous || !previous->valid || !previous->successor_valid ||
+      previous->successor_pc != pc)
+    return 0;
+  block = g->blocks + block_slot(pc);
+  if (!block->valid || block->pc != pc) return 0;
+  ++g->block_lookups;
+  ++g->block_cache_hits;
+  ++g->direct_link_hits;
+  return block;
+}
+static int safe_nofault_handler(uint32_t handler_id) {
+  return handler_id == BLINK_GEM_HANDLER_OP_NOP ||
+         handler_id == BLINK_GEM_HANDLER_OP_NOP_EV ||
+         handler_id == BLINK_GEM_HANDLER_OP_JMP ||
+         handler_id == BLINK_GEM_HANDLER_OP_JCC;
+}
+static struct blink_gem_block_entry* block_record(
+    struct blink_gem_machine* g, uint64_t pc, uint32_t handler_id,
+    uint8_t instruction_length) {
+  struct blink_gem_block_entry* block = g->blocks + block_slot(pc);
+  if (!block->valid || block->pc != pc) {
+    memset(block, 0, sizeof(*block));
+    block->pc = pc;
+    block->valid = 1;
+    ++g->blocks_created;
+  }
+  block->handler_id = handler_id;
+  block->instruction_length = instruction_length;
+  block->safe_nofault = safe_nofault_handler(handler_id);
+  return block;
+}
+static void block_observe_successor(struct blink_gem_machine* g,
+                                    struct blink_gem_block_entry* block,
+                                    uint64_t successor) {
+  uint64_t predicted;
+  if (!block || !block->valid) return;
+  if (block->handler_id == BLINK_GEM_HANDLER_OP_CALL_JVDS ||
+      block->handler_id == BLINK_GEM_HANDLER_OP_CALL_EQ) {
+    block->successor_pc = successor;
+    block->successor_valid = 1;
+    ++g->call_predictions;
+    if (g->return_stack_depth == BLINK_GEM_RETURN_STACK_ENTRIES) {
+      memmove(g->return_stack, g->return_stack + 1,
+              (BLINK_GEM_RETURN_STACK_ENTRIES - 1u) *
+                  sizeof(g->return_stack[0]));
+      --g->return_stack_depth;
+    }
+    g->return_stack[g->return_stack_depth++] =
+        block->pc + block->instruction_length;
+  } else if (block->handler_id == BLINK_GEM_HANDLER_OP_RET) {
+    ++g->return_predictions;
+    if (g->return_stack_depth) {
+      predicted = g->return_stack[--g->return_stack_depth];
+      if (predicted == successor) {
+        ++g->return_prediction_hits;
+        block->successor_pc = predicted;
+        block->successor_valid = 1;
+      } else {
+        ++g->return_prediction_misses;
+        block->successor_valid = 0;
+      }
+    } else {
+      ++g->return_prediction_misses;
+      block->successor_valid = 0;
+    }
+  } else {
+    block->successor_pc = successor;
+    block->successor_valid = 1;
+  }
+}
+static void invalidate_blocks(struct blink_gem_machine* g, uint64_t address,
+                              uint64_t size) {
+  uint64_t end;
+  size_t i;
+  if (!size || __builtin_add_overflow(address, size - 1, &end)) return;
+  for (i = 0; i < BLINK_GEM_BLOCK_CACHE_ENTRIES; ++i) {
+    struct blink_gem_block_entry* block = g->blocks + i;
+    uint64_t block_end;
+    if (!block->valid) continue;
+    block_end = block->pc + (block->instruction_length ? block->instruction_length : 1u) - 1u;
+    if ((block->pc <= end && block_end >= address) ||
+        (block->successor_valid && block->successor_pc >= address &&
+         block->successor_pc <= end)) {
+      memset(block, 0, sizeof(*block));
+      ++g->block_invalidations;
+    }
+  }
+  g->return_stack_depth = 0;
+}
