+static int guarded_range(struct blink_gem_machine* g, uint64_t address,
+                         uint64_t size) {
+  uint64_t end, page;
+  if (!size || __builtin_add_overflow(address, size - 1, &end)) return 1;
+  page = address & ~UINT64_C(4095);
+  for (;;) {
+    struct shadow_page* p = find_page(g, page);
+    if (!p || (p->protection & 8)) return 1;
+    if (page >= (end & ~UINT64_C(4095))) return 0;
+    page += 4096;
+  }
