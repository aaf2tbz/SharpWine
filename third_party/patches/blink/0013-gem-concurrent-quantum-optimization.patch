+static int end_quantum_after_instruction(struct blink_gem_machine* g) {
+  uint64_t page, end;
+  if (Lock(g->machine->xedd->op.rde) || Rep(g->machine->xedd->op.rde)) return 1;
+  if (g->machine->writesize <= 0) return 0;
+  page = (uint64_t)g->machine->writeaddr & ~UINT64_C(4095);
+  end = ((uint64_t)g->machine->writeaddr + (uint64_t)g->machine->writesize - 1) &
