+struct blink_gem_result blink_gem_machine_run(
+    struct blink_gem_machine* g, const struct blink_gem_run_request* request,
+    const struct blink_gem_state* in, struct blink_gem_state* out) {
+  struct blink_gem_result r;
+  struct blink_gem_state current, next;
+  uint32_t retired = 0;
+  size_t i;
+  if (!g || !request || !in || !out ||
+      request->abi_version != BLINK_GEM_RUN_REQUEST_ABI_VERSION ||
+      request->size != sizeof(*request) || !request->instruction_budget ||
+      request->stop_pc_count > 8 ||
+      (request->stop_pc_count && !request->stop_pcs))
+    return result(BLINK_GEM_INVALID);
+  current = *in;
+  g->batched_run = true;
+  g->batched_continuation = false;
+  while (retired < request->instruction_budget) {
+    for (i = 0; i < request->stop_pc_count; ++i) {
+      if (current.rip == request->stop_pcs[i]) {
+        g->batched_run = false;
+        *out = current;
+        r = result(BLINK_GEM_STOP_PC);
+        r.retired = retired;
+        return r;
+      }
+    }
+    if (request->async_stop && request->async_stop(request->async_opaque)) {
+      g->batched_run = false;
+      *out = current;
+      r = result(BLINK_GEM_ASYNC_STOP);
+      r.retired = retired;
+      return r;
+    }
+    r = blink_gem_machine_step(g, &current, &next);
+    if (r.outcome != BLINK_GEM_RETIRED || r.retired != 1) {
+      g->batched_run = false;
+      if (r.engine_status == BLINK_GEM_ENGINE_STATUS_RESTARTABLE_REP)
+        *out = next;
+      else
+        *out = current;
+      r.retired += retired;
+      return r;
+    }
+    current = next;
+    ++retired;
+  }
+  g->batched_run = false;
+  *out = current;
+  for (i = 0; i < request->stop_pc_count; ++i) {
+    if (current.rip == request->stop_pcs[i]) {
+      r = result(BLINK_GEM_STOP_PC);
+      r.retired = retired;
+      return r;
+    }
+  }
+  r = result(BLINK_GEM_RETIRED);
+  r.retired = retired;
   return r;
