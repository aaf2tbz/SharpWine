From 0000000000000000000000000000000000000022 Mon Sep 17 00:00:00 2001
From: SharpWine Contributors <sharpwine@example.invalid>
Date: Sat, 18 Jul 2026 00:00:00 +0000
Subject: [PATCH] gem: add native i386 avx foundation

Add a native VEX.128 execution seam for promoted floating-point operations,
scalar three-operand forms, VZEROUPPER, and VZEROALL. Correct the C5 vvvv high
bit decode, zero destination YMM uppers, and emit the same portable semantic
helper through Blink's real JIT hook. AVX CPUID remains masked until the full
256-bit and cross-lane family gate is complete.

---
diff -ruN --exclude=*.orig a/blink/avx.c b/blink/avx.c
--- a/blink/avx.c	1969-12-31 17:00:00
+++ b/blink/avx.c	2026-07-18 00:54:34
@@ -0,0 +1,146 @@
+/*-*- mode:c;indent-tabs-mode:nil;c-basic-offset:2;tab-width:8;coding:utf-8 -*-
+ * SPDX-License-Identifier: ISC
+ * Copyright 2026 SharpWine contributors
+ */
+#include "blink/avx.h"
+
+#include <string.h>
+
+#include "blink/jit.h"
+#include "blink/modrm.h"
+#include "blink/rde.h"
+
+static bool IsVex(const struct Machine *m) {
+  return m->xedd->bytes[0] == 0xc5 || m->xedd->bytes[0] == 0xc4;
+}
+
+static unsigned Prefix(u64 rde) {
+  if (Osz(rde)) return 1;
+  if (Rep(rde) == 3) return 2;
+  if (Rep(rde) == 2) return 3;
+  return 0;
+}
+
+bool IsAvxFoundationOp(struct Machine *m, u64 rde) {
+  unsigned op, pp;
+  if (!IsVex(m) || Opmap(rde) != XED_ILD_MAP1) return false;
+  op = Opcode(rde);
+  pp = Prefix(rde);
+  if (op == 0x77) return pp == 0;
+  if (Ymm(rde)) return false;
+  switch (op) {
+    case 0x10:
+      return pp >= 2;
+    case 0x14:
+    case 0x15:
+    case 0x54:
+    case 0x55:
+    case 0x56:
+    case 0x57:
+    case 0xc6:
+      return pp <= 1;
+    case 0x51:
+    case 0x58:
+    case 0x59:
+    case 0x5c:
+    case 0x5d:
+    case 0x5e:
+    case 0x5f:
+    case 0xc2:
+      return true;
+    case 0x52:
+    case 0x53:
+      return pp == 0 || pp == 2;
+    case 0x7c:
+    case 0x7d:
+    case 0xd0:
+      return pp == 1 || pp == 3;
+    default:
+      return false;
+  }
+}
+
+static bool UsesVreg(u64 rde) {
+  switch (Opcode(rde)) {
+    case 0x10:
+      return true;
+    case 0x14:
+    case 0x15:
+    case 0x54:
+    case 0x55:
+    case 0x56:
+    case 0x57:
+    case 0x58:
+    case 0x59:
+    case 0x5c:
+    case 0x5d:
+    case 0x5e:
+    case 0x5f:
+    case 0x7c:
+    case 0x7d:
+    case 0xc2:
+    case 0xc6:
+    case 0xd0:
+      return true;
+    case 0x51:
+    case 0x52:
+    case 0x53:
+      return Rep(rde) != 0;
+    default:
+      return false;
+  }
+}
+
+static u64 RedirectRegisterSource(u64 rde, unsigned reg) {
+  rde &= ~((u64)kRexbRmMask | UINT64_C(000060000000));
+  rde |= (u64)(reg & 7) << 7;
+  rde |= UINT64_C(3) << 22;
+  return rde;
+}
+
+static void RunAvxFoundation(P) {
+  nexgen32e_f legacy;
+  u8 source[16], scratch[16];
+  unsigned dst, tmp;
+
+  if (Opcode(rde) == 0x77) {
+    unsigned i;
+    for (i = 0; i < 8; ++i) {
+      memset(m->ymm_upper[i], 0, 16);
+      if (Ymm(rde)) memset(m->xmm[i], 0, 16);
+    }
+    return;
+  }
+
+  dst = RexrReg(rde);
+  if (UsesVreg(rde)) {
+    memcpy(m->xmm[dst], m->xmm[Vreg(rde)], 16);
+  }
+  if (IsModrmRegister(rde)) {
+    memcpy(source, m->xmm[RexbRm(rde)], 16);
+    tmp = (dst + 1) & 7;
+    memcpy(scratch, m->xmm[tmp], 16);
+    memcpy(m->xmm[tmp], source, 16);
+    rde = RedirectRegisterSource(rde, tmp);
+  } else {
+    tmp = 8;
+  }
+
+  legacy = GetOp(Mopcode(rde));
+  legacy(A);
+  if (tmp < 8 && tmp != dst) memcpy(m->xmm[tmp], scratch, 16);
+  memset(m->ymm_upper[dst], 0, 16);
+}
+
+void OpAvxFoundation(P) {
+  if (IsMakingPath(m)) {
+    Jitter(A,
+           "a3i"
+           "a2i"
+           "a1i"
+           "c",
+           uimm0, disp, rde, RunAvxFoundation);
+  } else {
+    RunAvxFoundation(A);
+  }
+}
