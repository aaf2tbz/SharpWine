       }
       if (g->guest_mode == BLINK_GEM_GUEST_LEGACY_32 &&
-          masked_legacy_vex(g, fetch_address, m->xedd->op.rde)) {
+          masked_legacy_vex(g, fetch_address, m->xedd->op.rde) &&
+          !IsAvxFoundationOp(m, m->xedd->op.rde)) {
         m->canhalt = false;
         return result(BLINK_GEM_UNSUPPORTED);
       }
diff -ruN --exclude=*.orig a/blink/machine.c b/blink/machine.c
--- a/blink/machine.c	2026-07-18 00:48:38
+++ b/blink/machine.c	2026-07-18 00:57:26
@@ -2293,6 +2293,14 @@
   }
 }
 
+bool IsAvxFoundationOp(struct Machine *, u64);
+void OpAvxFoundation(P);
+
+nexgen32e_f GetOpForRde(struct Machine *m, long rde) {
+  if (IsAvxFoundationOp(m, rde)) return OpAvxFoundation;
+  return GetOp(Mopcode(rde));
+}
+
 int GemHandlerId(nexgen32e_f handler, long rde, bool legacy32) {
   /* The legacy profile deliberately masks state families which GEM's fixed
    * i386 context cannot restore and host-state handlers owned by the adapter.
@@ -2389,7 +2397,7 @@
   uimm0 = m->xedd->op.uimm0;
   m->oplen = Oplength(rde);
   m->ip += Oplength(rde);
-  GetOp(Mopcode(rde))(A);
+  GetOpForRde(m, rde)(A);
   if (m->stashaddr) CommitStash(m);
   m->oplen = 0;
 }
@@ -2441,7 +2449,7 @@
   m->ip += Oplength(rde);
   // call the c implementation of the opcode
   m->gemcompilingop = m->gemembed;
-  GetOp(Mopcode(rde))(A);
+  GetOpForRde(m, rde)(A);
   m->gemcompilingop = false;
   // cleanup after ReserveAddress() if a memory access overlapped a page
   if (m->stashaddr) {
