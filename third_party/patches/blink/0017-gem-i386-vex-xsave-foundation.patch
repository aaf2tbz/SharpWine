@@ -154,6 +154,15 @@
 void Op101(P) {
   bool ismem;
   ismem = !IsModrmRegister(rde);
+  if (!ismem && Modrm(rde) == 0xd0) {
+    if (Read32(m->cx)) ThrowProtectionFault(m);
+    Write32(m->ax, m->xcr0);
+    Write32(m->dx, m->xcr0 >> 32);
+    return;
+  }
+  if (!ismem && Modrm(rde) == 0xd1) {
+    ThrowProtectionFault(m);
+  }
   switch (ModrmReg(rde)) {
 #ifndef DISABLE_METAL
     case 0:
--- a/blink/x86.c
