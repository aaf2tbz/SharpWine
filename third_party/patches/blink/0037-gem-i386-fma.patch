+static bool SupportsFma(u64 rde) {
+  unsigned op;
+  if (Opmap(rde) != XED_ILD_MAP2 || Prefix(rde) != 1) return false;
+  op = Opcode(rde);
+  if ((op >> 4) < 9 || (op >> 4) > 11) return false;
+  if ((op & 15) < 6) return false;
+  if ((op & 15) >= 8 && (op & 1)) return !Ymm(rde);
+  return true;
+}
