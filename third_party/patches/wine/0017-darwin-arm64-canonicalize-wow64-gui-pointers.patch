diff --git a/dlls/winemac.drv/unixlib.h b/dlls/winemac.drv/unixlib.h
index dc22da02d2..043c9710e6 100644
--- a/dlls/winemac.drv/unixlib.h
+++ b/dlls/winemac.drv/unixlib.h
@@ -73,5 +73,29 @@
 
 static inline void *param_ptr(UINT64 param)
 {
+#if defined(__APPLE__) && defined(__aarch64__) && defined(_WIN64)
+    MEMORY_BASIC_INFORMATION info;
+    ULONG_PTR primary, alternate;
+    SIZE_T ret_len;
+
+    /* WoW64 parameter blocks contain 32-bit guest pointers.  macOS reserves
+     * the low 4 GiB.  Probe both Wine shadow ranges because PE images below
+     * 0x7f000000 can still live in the high shadow, unlike ordinary heaps. */
+    if (param && param <= UINT32_MAX)
+    {
+        primary = (param >= 0x7f000000 ? UINT64_C(0x10000000000)
+                                       : UINT64_C(0x8000000000)) + param;
+        alternate = (primary == UINT64_C(0x10000000000) + param ? UINT64_C(0x8000000000)
+                                                                  : UINT64_C(0x10000000000)) + param;
+        if (!NtQueryVirtualMemory( NtCurrentProcess(), (void *)primary, MemoryBasicInformation,
+                                   &info, sizeof(info), &ret_len ) && info.State != MEM_FREE)
+            param = primary;
+        else if (!NtQueryVirtualMemory( NtCurrentProcess(), (void *)alternate, MemoryBasicInformation,
+                                        &info, sizeof(info), &ret_len ) && info.State != MEM_FREE)
+            param = alternate;
+        else
+            param = primary;
+    }
+#endif
     return (void *)(UINT_PTR)param;
 }
diff --git a/dlls/winspool.drv/cups.c b/dlls/winspool.drv/cups.c
index 89fc9688de..56d2a21606 100644
--- a/dlls/winspool.drv/cups.c
+++ b/dlls/winspool.drv/cups.c
@@ -72,6 +72,20 @@
 
 WINE_DEFAULT_DEBUG_CHANNEL(winspool);
 
+#if defined(__APPLE__) && defined(__aarch64__) && defined(_WIN64)
+/* The macOS ARM64 WoW64 runtime shadows 32-bit mappings above 4 GiB.  These
+ * wrappers decode guest pointers embedded in 32-bit Unix-call parameter
+ * blocks, so zero-extending them with ULongToPtr produces unmapped addresses. */
+static inline void *wow64_guest_ptr( ULONG addr )
+{
+    if (!addr) return NULL;
+    return (void *)(ULONG_PTR)((addr >= 0x7f000000 ? UINT64_C(0x10000000000)
+                                                   : UINT64_C(0x8000000000)) + addr);
+}
+#else
+#define wow64_guest_ptr(addr) ULongToPtr(addr)
+#endif
+
 #ifdef SONAME_LIBCUPS
 
 static void *libcups_handle;
@@ -392,17 +406,17 @@ static NTSTATUS wow64_enum_printers( void *args )
     unsigned int i;
     struct enum_printers_params params =
     {
-        ULongToPtr( params32->printers ),
-        ULongToPtr( params32->size ),
-        ULongToPtr( params32->num )
+        wow64_guest_ptr( params32->printers ),
+        wow64_guest_ptr( params32->size ),
+        wow64_guest_ptr( params32->num )
     };
 
     if (!(status = enum_printers( &params )))
     {
         /* convert structures in place */
-        struct printer_info *info = ULongToPtr( params32->printers );
+        struct printer_info *info = wow64_guest_ptr( params32->printers );
         struct printer_info32 *info32 = (struct printer_info32 *)info;
-        unsigned int num = *(unsigned int *)ULongToPtr( params32->num );
+        unsigned int num = *(unsigned int *)wow64_guest_ptr( params32->num );
 
         for (i = 0; i < num; i++)
         {
@@ -425,8 +439,8 @@ static NTSTATUS wow64_get_default_page_size( void *args )
 
     struct get_default_page_size_params params =
     {
-        ULongToPtr( params32->name ),
-        ULongToPtr( params32->name_size )
+        wow64_guest_ptr( params32->name ),
+        wow64_guest_ptr( params32->name_size )
     };
 
     return get_default_page_size( &params );
@@ -442,8 +456,8 @@ static NTSTATUS wow64_get_ppd( void *args )
 
     struct get_ppd_params params =
     {
-        ULongToPtr( params32->printer ),
-        ULongToPtr( params32->ppd )
+        wow64_guest_ptr( params32->printer ),
+        wow64_guest_ptr( params32->ppd )
     };
 
     return get_ppd( &params );
