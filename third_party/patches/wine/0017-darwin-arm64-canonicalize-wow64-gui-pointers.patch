diff --git a/dlls/ntdll/unix/env.c b/dlls/ntdll/unix/env.c
index bb33deb4cf..ecff08ca99 100644
--- a/dlls/ntdll/unix/env.c
+++ b/dlls/ntdll/unix/env.c
@@ -2345,6 +2345,18 @@ void WINAPI RtlInitCodePageTable( USHORT *ptr, CPTABLEINFO *info )
 {
     static const CPTABLEINFO utf8_cpinfo = { CP_UTF8, 4, '?', 0xfffd, '?', '?' };
 
+#if defined(__APPLE__) && defined(__aarch64__) && defined(_WIN64)
+    /* Native WoW64 callers can obtain these pointers from the 32-bit PEB.
+     * macOS cannot map the low 4 GiB, so turn the embedded guest addresses
+     * back into their canonical shadow mappings before dereferencing them. */
+    if (ptr && (ULONG_PTR)ptr <= UINT32_MAX)
+        ptr = (USHORT *)(ULONG_PTR)(((ULONG_PTR)ptr >= 0x7f000000 ? UINT64_C(0x10000000000)
+                                                                    : UINT64_C(0x8000000000)) + (ULONG_PTR)ptr);
+    if (info && (ULONG_PTR)info <= UINT32_MAX)
+        info = (CPTABLEINFO *)(ULONG_PTR)(((ULONG_PTR)info >= 0x7f000000 ? UINT64_C(0x10000000000)
+                                                                          : UINT64_C(0x8000000000)) + (ULONG_PTR)info);
+#endif
+
     if (ptr[1] == CP_UTF8) *info = utf8_cpinfo;
     else init_codepage_table( ptr, info );
 }
diff --git a/dlls/ntdll/unix/signal_arm64.c b/dlls/ntdll/unix/signal_arm64.c
index 1c314b9843..0c95256449 100644
--- a/dlls/ntdll/unix/signal_arm64.c
+++ b/dlls/ntdll/unix/signal_arm64.c
@@ -82,6 +82,7 @@ struct arm64_thread_data
     BOOL gem_logged_syscall;
     BOOL gem_logged_unix_call;
     BOOL gem_logged_callback;
+    ULONG gem_callback_sequence;
     struct gem_callback_state *gem_callback;
     struct gem_thread_context *gem_x64_start_context;
 #endif
@@ -1641,6 +1642,25 @@ NTSTATUS KeUserModeCallback( ULONG id, const void *args, ULONG len, void **ret_p
     ULONG64 sp = (frame->sp - offsetof( struct callback_stack_layout, args_data[len] ) - 16) & ~15;
     struct callback_stack_layout *stack = (struct callback_stack_layout *)sp;
 
+#if defined(__APPLE__)
+    {
+        PEB32 *peb32 = NULL;
+        NtQueryInformationProcess( GetCurrentProcess(), ProcessWow64Information,
+                                   &peb32, sizeof(peb32), NULL );
+        /* A WoW64 dependency can enter win32u before user32's process attach
+         * publishes the 32-bit callback table. These initialization callbacks
+         * are optional; report an empty successful result until dispatch is
+         * actually possible instead of calling through PEB32+0x2c == NULL. */
+        if (peb32 && !peb32->KernelCallbackTable)
+        {
+            TRACE_(gem)("defer early WoW64 callback id=%u\n", id);
+            *ret_ptr = NULL;
+            *ret_len = 0;
+            return STATUS_SUCCESS;
+        }
+    }
+#endif
+
     if ((char *)get_kernel_stack( data ) + min_kernel_stack > (char *)&frame) return STATUS_STACK_OVERFLOW;
 
     stack->args = stack->args_data;
@@ -1673,12 +1693,15 @@ NTSTATUS KeUserModeCallback( ULONG id, const void *args, ULONG len, void **ret_p
          * after the translated callback has produced its synchronous result. */
         callback->frame.pc = UINT64_MAX - 15;
         arm64_data->gem_callback = callback;
-        if (!arm64_data->gem_logged_callback)
+        arm64_data->gem_callback_sequence++;
+        if (arm64_data->gem_callback_sequence <= 32)
         {
-            TRACE_(gem)("callback enter id=%u pc=%p return=%p sp=%p\n", id,
+            TRACE_(gem)("callback enter seq=%u id=%u state=%p previous=%p pc=%p return=%p "
+                        "outer-pc=%p outer-lr=%p sp=%p\n",
+                        arm64_data->gem_callback_sequence, id, callback, previous,
                         pKiUserCallbackDispatcher, (void *)(uintptr_t)callback->frame.pc,
+                        (void *)(uintptr_t)outer_frame.pc, (void *)(uintptr_t)outer_frame.lr,
                         (void *)(uintptr_t)sp );
-            arm64_data->gem_logged_callback = TRUE;
         }
         frame->sp = sp;
         frame->pc = (ULONG64)pKiUserCallbackDispatcher;
@@ -1696,6 +1719,12 @@ NTSTATUS KeUserModeCallback( ULONG id, const void *args, ULONG len, void **ret_p
             if (run_status != GEM_WINE_BUDGET_EXPIRED) break;
             context.stop_reason = GEM_STOP_NONE;
         }
+        if (arm64_data->gem_callback_sequence <= 32)
+            TRACE_(gem)("callback stop seq=%u status=%s outcome=%u reason=%u pc=%p "
+                        "state=%p active=%p previous=%p\n",
+                        arm64_data->gem_callback_sequence, gem_wine_status_name(run_status),
+                        result.outcome, result.stop_reason, (void *)(uintptr_t)output.pc,
+                        callback, arm64_data->gem_callback, previous );
         if (run_status == GEM_WINE_OK && result.outcome == GEM_WINE_RUN_COMPLETE &&
             arm64_data->gem_callback == previous)
             callback_status = (NTSTATUS)output.x[0];
@@ -1734,6 +1763,7 @@ NTSTATUS WINAPI NtCallbackReturn( void *ret_ptr, ULONG ret_len, NTSTATUS status
         struct gem_callback_state *callback = arm64_data->gem_callback;
         if (callback)
         {
+            ULONG sequence = arm64_data->gem_callback_sequence;
             *callback->ret_ptr = ret_ptr;
             *callback->ret_len = ret_len;
             *frame = callback->frame;
@@ -1742,8 +1772,11 @@ NTSTATUS WINAPI NtCallbackReturn( void *ret_ptr, ULONG ret_len, NTSTATUS status
             frame->restore_flags |= CONTEXT_FULL;
             syscall_frame_fixup_for_fastpath( frame );
             arm64_data->gem_callback = callback->previous;
-            TRACE_(gem)("callback return status=%#x pc=%p sp=%p\n", (unsigned int)status,
-                        (void *)(uintptr_t)frame->pc, (void *)(uintptr_t)frame->sp );
+            if (sequence <= 32)
+                TRACE_(gem)("callback return seq=%u state=%p previous=%p status=%#x pc=%p "
+                            "sp=%p\n", sequence, callback, callback->previous,
+                            (unsigned int)status, (void *)(uintptr_t)frame->pc,
+                            (void *)(uintptr_t)frame->sp );
             free( callback );
             return status;
         }
diff --git a/dlls/win32u/gdiobj.c b/dlls/win32u/gdiobj.c
index e861dee167..0dc352a620 100644
--- a/dlls/win32u/gdiobj.c
+++ b/dlls/win32u/gdiobj.c
@@ -583,6 +583,10 @@ static void init_gdi_shared(void)
     RtlGetCurrentPeb()->GdiSharedHandleTable = gdi_shared;
 }
 
+static pthread_once_t gdi_once = PTHREAD_ONCE_INIT;
+static _Thread_local BOOL inside_gdi_init;
+static void init_gdi_once(void);
+
 /***********************************************************************
  *           GetStockObject    (win32u.so)
  */
@@ -721,6 +725,18 @@ HGDIOBJ alloc_gdi_handle( struct gdi_obj_header *obj, DWORD type, const struct g
 
     assert( type );  /* type 0 is reserved to mark free entries */
 
+    /* A WoW64 dependency can allocate a GDI object before user32 reaches its
+     * normal initialization call.  Initialize the complete stock-object set
+     * first so the early object cannot consume one of its fixed handle slots.
+     * The thread-local guard lets stock creation recurse into this allocator;
+     * other threads still block in pthread_once until initialization ends. */
+    if (!inside_gdi_init) pthread_once( &gdi_once, init_gdi_once );
+    if (!gdi_shared)
+    {
+        WARN( "failed to initialize the GDI shared handle table\n" );
+        return 0;
+    }
+
     pthread_mutex_lock( &gdi_lock );
 
     entry = next_free;
@@ -1029,19 +1045,29 @@ BOOL WINAPI NtGdiSetColorAdjustment( HDC hdc, const COLORADJUSTMENT *ca )
     return FALSE;
 }
 
-void gdi_init(void)
+static void init_gdi_once(void)
 {
     pthread_mutexattr_t attr;
     unsigned int dpi;
 
+    inside_gdi_init = TRUE;
     pthread_mutexattr_init( &attr );
     pthread_mutexattr_settype( &attr, PTHREAD_MUTEX_RECURSIVE );
     pthread_mutex_init( &gdi_lock, &attr );
     pthread_mutexattr_destroy( &attr );
-
     init_gdi_shared();
-    if (!gdi_shared) return;
+    if (!gdi_shared)
+    {
+        inside_gdi_init = FALSE;
+        return;
+    }
 
     dpi = font_init();
     init_stock_objects( dpi );
+    inside_gdi_init = FALSE;
+}
+
+void gdi_init(void)
+{
+    pthread_once( &gdi_once, init_gdi_once );
 }
