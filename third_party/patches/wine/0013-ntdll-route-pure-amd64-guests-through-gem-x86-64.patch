+static void classify_main_guest( void *module )
+{
+    const IMAGE_DOS_HEADER *dos = module;
+    const IMAGE_NT_HEADERS64 *nt;
+    const IMAGE_DATA_DIRECTORY *dir;
+    const IMAGE_LOAD_CONFIG_DIRECTORY64 *loadcfg;
+    SIZE_T chpe_end = offsetof( IMAGE_LOAD_CONFIG_DIRECTORY64, CHPEMetadataPointer ) +
+                      sizeof(loadcfg->CHPEMetadataPointer);
+
+    main_guest_mode = MAIN_GUEST_NATIVE;
+    if (current_machine != IMAGE_FILE_MACHINE_ARM64 ||
+        main_image_info.Machine != IMAGE_FILE_MACHINE_AMD64) return;
+
+    /* An ordinary PE32+ AMD64 image and an ARM64EC/ARM64X image use the same
+     * COFF machine. Classify from the checked, already-mapped load-config
+     * metadata instead of treating every AMD64 image as hybrid. */
+    if (!module || dos->e_magic != IMAGE_DOS_SIGNATURE)
+        fatal_error( "invalid AMD64 main image header\n" );
+    nt = (const IMAGE_NT_HEADERS64 *)((const char *)module + dos->e_lfanew);
+    if (nt->Signature != IMAGE_NT_SIGNATURE ||
+        nt->FileHeader.Machine != IMAGE_FILE_MACHINE_AMD64 ||
+        nt->OptionalHeader.Magic != IMAGE_NT_OPTIONAL_HDR64_MAGIC)
+        fatal_error( "invalid AMD64 PE32+ main image\n" );
+
+    main_guest_mode = MAIN_GUEST_X86_64;
+    if (nt->OptionalHeader.NumberOfRvaAndSizes <= IMAGE_DIRECTORY_ENTRY_LOAD_CONFIG) return;
+    dir = &nt->OptionalHeader.DataDirectory[IMAGE_DIRECTORY_ENTRY_LOAD_CONFIG];
+    if (!dir->VirtualAddress || dir->Size < chpe_end ||
+        dir->VirtualAddress > nt->OptionalHeader.SizeOfImage ||
+        chpe_end > nt->OptionalHeader.SizeOfImage - dir->VirtualAddress) return;
+    loadcfg = (const IMAGE_LOAD_CONFIG_DIRECTORY64 *)((const char *)module + dir->VirtualAddress);
+    if (loadcfg->Size >= chpe_end && loadcfg->CHPEMetadataPointer)
+        main_guest_mode = MAIN_GUEST_ARM64EC;
+}
+
