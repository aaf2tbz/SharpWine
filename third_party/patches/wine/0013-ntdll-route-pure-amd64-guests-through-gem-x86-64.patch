         status = find_builtin_dll( nt_name, NULL, module, &size, &main_image_info, 0, 0,
                                    search_machine, load_machine, FALSE, 0 );
+    if (NT_SUCCESS(status)) classify_main_guest( *module );
     return status;
 }
 
