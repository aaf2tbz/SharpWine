+struct gem_amd64_machine_frame
+{
+    ULONG64 rip;
+    ULONG64 cs;
+    ULONG64 eflags;
+    ULONG64 rsp;
+    ULONG64 ss;
+};
+
+struct gem_amd64_exception_stack
+{
+    AMD64_CONTEXT context;
+    CONTEXT_EX context_ex;
+    EXCEPTION_RECORD rec;
+    ULONG64 align;
+    struct gem_amd64_machine_frame machine_frame;
+    ULONG64 align2;
+};
+
+C_ASSERT( offsetof(struct gem_amd64_exception_stack, rec) == 0x4f0 );
+C_ASSERT( offsetof(struct gem_amd64_exception_stack, machine_frame) == 0x590 );
+C_ASSERT( sizeof(struct gem_amd64_exception_stack) == 0x5c0 );
+
+static void gem_context_to_amd64( const struct gem_thread_context *source,
+                                  AMD64_CONTEXT *context )
+{
+    memset( context, 0, sizeof(*context) );
+    context->ContextFlags = CONTEXT_AMD64_FULL;
+    context->MxCsr = source->x64_mxcsr;
+    context->EFlags = source->x64_rflags;
+    context->Rax = source->x[8];
+    context->Rcx = source->x[0];
+    context->Rdx = source->x[1];
+    context->Rbx = source->x[27];
+    context->Rsp = source->sp;
+    context->Rbp = source->x[29];
+    context->Rsi = source->x[25];
+    context->Rdi = source->x[26];
+    context->R8 = source->x[2];
+    context->R9 = source->x[3];
+    context->R10 = source->x[4];
+    context->R11 = source->x[5];
+    context->R12 = source->x[19];
+    context->R13 = source->x[20];
+    context->R14 = source->x[21];
+    context->R15 = source->x[22];
+    context->Rip = source->pc;
+    context->FltSave.ControlWord = source->x64_fcw;
+    context->FltSave.StatusWord = source->x64_fsw;
+    context->FltSave.MxCsr = source->x64_mxcsr;
+    memcpy( context->FltSave.XmmRegisters, source->v, sizeof(source->v) );
+    memcpy( context->FltSave.FloatRegisters, source->x87, sizeof(source->x87) );
+}
+
+static void gem_context_from_amd64( struct gem_thread_context *context,
+                                    const AMD64_CONTEXT *source )
+{
+    DWORD flags = source->ContextFlags & ~CONTEXT_AMD64;
+
+    if (flags & CONTEXT_AMD64_INTEGER)
+    {
+        context->x[8] = source->Rax;
+        context->x[0] = source->Rcx;
+        context->x[1] = source->Rdx;
+        context->x[27] = source->Rbx;
+        context->x[25] = source->Rsi;
+        context->x[26] = source->Rdi;
+        context->x[2] = source->R8;
+        context->x[3] = source->R9;
+        context->x[4] = source->R10;
+        context->x[5] = source->R11;
+        context->x[19] = source->R12;
+        context->x[20] = source->R13;
+        context->x[21] = source->R14;
+        context->x[22] = source->R15;
+    }
+    if (flags & CONTEXT_AMD64_CONTROL)
+    {
+        context->sp = source->Rsp;
+        context->x[29] = source->Rbp;
+        context->pc = source->Rip;
+        context->x64_rflags = source->EFlags;
+    }
+    if (flags & CONTEXT_AMD64_FLOATING_POINT)
+    {
+        context->x64_mxcsr = source->MxCsr;
+        context->x64_fcw = source->FltSave.ControlWord;
+        context->x64_fsw = source->FltSave.StatusWord;
+        memcpy( context->v, source->FltSave.XmmRegisters, sizeof(context->v) );
+        memcpy( context->x87, source->FltSave.FloatRegisters, sizeof(context->x87) );
+    }
+    context->x[18] = context->teb;
+    context->stop_reason = GEM_STOP_NONE;
+}
+
+static NTSTATUS gem_dispatch_exception_x86_64( struct gem_thread_context *context,
+                                               const EXCEPTION_RECORD *rec )
+{
+    struct gem_amd64_exception_stack stack = {0};
+    ULONG64 stack_address;
+
+    if (!pKiUserExceptionDispatcher) return STATUS_DLL_INIT_FAILED;
+    gem_context_to_amd64( context, &stack.context );
+    stack.context_ex.Legacy.Length = sizeof(stack.context);
+    stack.context_ex.Legacy.Offset = -(LONG)sizeof(stack.context);
+    stack.context_ex.XState.Length = 25;
+    stack.context_ex.XState.Offset = 0;
+    stack.context_ex.All.Length = sizeof(stack.context) + 24;
+    stack.context_ex.All.Offset = -(LONG)sizeof(stack.context);
+    stack.rec = *rec;
+    stack.machine_frame.rip = stack.context.Rip;
+    stack.machine_frame.rsp = stack.context.Rsp;
+    stack_address = (context->sp - sizeof(stack)) & ~(ULONG64)63;
+    if (virtual_uninterrupted_write_memory( (void *)(uintptr_t)stack_address, &stack,
+                                            sizeof(stack) ))
+        return STATUS_ACCESS_VIOLATION;
+    context->x[29] = stack.context.Rbp;
+    context->sp = stack_address;
+    context->pc = (ULONG64)(uintptr_t)pKiUserExceptionDispatcher;
+    context->stop_reason = GEM_STOP_NONE;
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS gem_call_syscall_x86_64( struct gem_thread_context *context, BOOL *continued )
+{
+    typedef ULONG_PTR (*syscall_func)(ULONG_PTR, ULONG_PTR, ULONG_PTR, ULONG_PTR,
+                                     ULONG_PTR, ULONG_PTR, ULONG_PTR, ULONG_PTR,
+                                     ULONG_PTR, ULONG_PTR, ULONG_PTR, ULONG_PTR,
+                                     ULONG_PTR, ULONG_PTR, ULONG_PTR, ULONG_PTR);
+    SYSTEM_SERVICE_TABLE *table;
+    const ULONG id = context->x[8];
+    const ULONG table_id = (id >> 12) & 3;
+    const ULONG service_id = id & 0xfff;
+    const ULONG_PTR *stack = (const ULONG_PTR *)(uintptr_t)(context->sp + 0x30);
+    ULONG_PTR args[12] = {0};
+    ULONG stack_bytes;
+    syscall_func func;
+
+    *continued = FALSE;
+
+    table = &KeServiceDescriptorTable[table_id];
+    if (service_id >= table->ServiceLimit) return STATUS_INVALID_SYSTEM_SERVICE;
+    stack_bytes = table->ArgumentTable[service_id];
+    stack_bytes = stack_bytes > 4 * sizeof(ULONG_PTR) ? stack_bytes - 4 * sizeof(ULONG_PTR) : 0;
+    if (stack_bytes > sizeof(args)) return STATUS_INVALID_PARAMETER;
+    if (stack_bytes &&
+        virtual_uninterrupted_read_memory( stack, args, stack_bytes ) != stack_bytes)
+        return STATUS_ACCESS_VIOLATION;
+    func = (syscall_func)(uintptr_t)table->ServiceTable[service_id];
+    if ((void *)(uintptr_t)func == (void *)(uintptr_t)NtContinue)
+    {
+        AMD64_CONTEXT amd64;
+
+        if (context->x[1]) return STATUS_NOT_SUPPORTED;
+        if (virtual_uninterrupted_read_memory( (const void *)(uintptr_t)context->x[0],
+                                               &amd64, sizeof(amd64) ) != sizeof(amd64))
+            return STATUS_ACCESS_VIOLATION;
+        gem_context_from_amd64( context, &amd64 );
+        *continued = TRUE;
+        return STATUS_SUCCESS;
+    }
+    return func( context->x[4], context->x[1], context->x[2], context->x[3],
+                 args[0], args[1], args[2], args[3], args[4], args[5],
+                 args[6], args[7], args[8], args[9], args[10], args[11] );
+}
+
+static enum gem_wine_status gem_signal_boundary_x86_64(
+    struct thread_data *data, const struct gem_wine_boundary_request *request,
+    struct gem_wine_boundary_response *response )
+{
+    struct gem_thread_context *context = &response->context;
+    EXCEPTION_RECORD rec = {0};
+    NTSTATUS status = STATUS_SUCCESS;
+    ULONG64 return_pc;
+    BOOL continued;
+    BYTE opcode[2];
+
+    response->action = GEM_WINE_BOUNDARY_RESUME;
+    *context = request->context;
+    context->stop_reason = GEM_STOP_NONE;
+    switch (request->event)
+    {
+    case GEM_WINE_EVENT_SYSCALL:
+        status = gem_call_syscall_x86_64( context, &continued );
+        if (continued)
+        {
+            TRACE_(gem)("x86_64 NtContinue status=%#x pc=%p sp=%p\n", status,
+                        (void *)(uintptr_t)context->pc, (void *)(uintptr_t)context->sp );
+            break;
+        }
+        if (virtual_uninterrupted_read_memory( (const void *)(uintptr_t)context->pc,
+                                               opcode, sizeof(opcode) ) == sizeof(opcode) &&
+            opcode[0] == 0x0f && opcode[1] == 0x05)
+        {
+            context->x[0] = context->pc + sizeof(opcode); /* syscall saves RIP in RCX */
+            context->x[5] = context->x64_rflags;          /* and RFLAGS in R11 */
+            context->x[8] = status;
+            context->pc += sizeof(opcode);
+            TRACE_(gem)("x86_64 direct syscall id=%#llx status=%#x return=%p\n",
+                        (unsigned long long)request->context.x[8], status,
+                        (void *)(uintptr_t)context->pc );
+            break;
+        }
+        if (virtual_uninterrupted_read_memory( (const void *)(uintptr_t)context->sp,
+                                               &return_pc, sizeof(return_pc) ) != sizeof(return_pc))
+        {
+            response->action = GEM_WINE_BOUNDARY_FAIL;
+            break;
+        }
+        context->x[8] = status;
+        context->pc = return_pc;
+        context->sp += sizeof(return_pc);
+        TRACE_(gem)("x86_64 syscall id=%#llx status=%#x return=%p\n",
+                    (unsigned long long)request->context.x[8], status,
+                    (void *)(uintptr_t)return_pc );
+        break;
+    case GEM_WINE_EVENT_UNIX_CALL:
+    {
+        const unixlib_entry_t *table = (const unixlib_entry_t *)(uintptr_t)context->x[0];
+        const ULONG64 index = context->x[1];
+        context->x[8] = table[index]( (void *)(uintptr_t)context->x[2] );
+        if (virtual_uninterrupted_read_memory( (const void *)(uintptr_t)context->sp,
+                                               &return_pc, sizeof(return_pc) ) != sizeof(return_pc))
+        {
+            response->action = GEM_WINE_BOUNDARY_FAIL;
+            break;
+        }
+        context->pc = return_pc;
+        context->sp += sizeof(return_pc);
+        TRACE_(gem)("x86_64 unix-call index=%llu status=%#llx return=%p\n",
+                    (unsigned long long)index, (unsigned long long)context->x[8],
+                    (void *)(uintptr_t)return_pc );
+        break;
