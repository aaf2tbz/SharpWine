From e3fd4b86ac067374116e3e93bf963caa0d1101df Mon Sep 17 00:00:00 2001
From: Avery Felts <averyfelts@users.noreply.github.com>
Date: Mon, 13 Jul 2026 22:43:58 -0600
Subject: [PATCH 13/13] ntdll: route pure AMD64 guests through GEM x86_64

---
 dlls/ntdll/ntdll.spec          |   4 +-
 dlls/ntdll/signal_x86_64.c     |  11 ++
 dlls/ntdll/unix/gem.c          |  26 +++
 dlls/ntdll/unix/loader.c       |  66 ++++++-
 dlls/ntdll/unix/signal_arm64.c | 326 ++++++++++++++++++++++++++++++++-
 dlls/ntdll/unix/unix_private.h |  18 +-
 6 files changed, 441 insertions(+), 10 deletions(-)

diff --git a/dlls/ntdll/ntdll.spec b/dlls/ntdll/ntdll.spec
index 32da9b2a28..fb2c5d66b8 100644
--- a/dlls/ntdll/ntdll.spec
+++ b/dlls/ntdll/ntdll.spec
@@ -1767,8 +1767,8 @@
 @ extern -private __wine_syscall_dispatcher
 @ extern -private __wine_unix_call_dispatcher
 @ extern -private -arch=arm64ec __wine_unix_call_dispatcher_arm64ec
-@ cdecl -private -arch=arm64,arm64ec __wine_gem_syscall_dispatcher()
-@ cdecl -private -arch=arm64,arm64ec __wine_gem_unix_call_dispatcher()
+@ cdecl -private -arch=arm64,arm64ec,x86_64 __wine_gem_syscall_dispatcher()
+@ cdecl -private -arch=arm64,arm64ec,x86_64 __wine_gem_unix_call_dispatcher()
 @ extern -private __wine_unixlib_handle
 
 # Debugging
diff --git a/dlls/ntdll/signal_x86_64.c b/dlls/ntdll/signal_x86_64.c
index 29fadc7224..5ef98a5d9c 100644
--- a/dlls/ntdll/signal_x86_64.c
+++ b/dlls/ntdll/signal_x86_64.c
@@ -985,6 +985,17 @@ void __cdecl NTDLL_longjmp( _JUMP_BUFFER *buf, int retval )
  *           RtlUserThreadStart (NTDLL.@)
  */
 #ifdef __WINE_PE_BUILD
+/* Guest-resident, exported boundary addresses for the native ARM64 GEM host.
+ * The dispatcher data slots point here only for pure AMD64 execution. GEM
+ * stops before fetching either instruction, so these fail-closed bodies must
+ * never execute as x86_64 host code. */
+__ASM_GLOBAL_FUNC( __wine_gem_syscall_dispatcher,
+                   "ud2\n\t"
+                   "ret" )
+__ASM_GLOBAL_FUNC( __wine_gem_unix_call_dispatcher,
+                   "ud2\n\t"
+                   "ret" )
+
 __ASM_GLOBAL_FUNC( RtlUserThreadStart,
                    "subq $0x28,%rsp\n\t"
                    ".seh_stackalloc 0x28\n\t"
diff --git a/dlls/ntdll/unix/gem.c b/dlls/ntdll/unix/gem.c
index f1d4db4d9f..f43e020217 100644
--- a/dlls/ntdll/unix/gem.c
+++ b/dlls/ntdll/unix/gem.c
@@ -89,6 +89,27 @@ void gem_prepare_arm64ec(void)
         gem_fail("ARM64EC preparation lock", GEM_WINE_ENGINE_ERROR);
 }
 
+NTSTATUS gem_prepare_x86_64(void *module, SIZE_T image_size,
+                            void *syscall_boundary, void *unix_call_boundary)
+{
+    struct gem_wine_x86_64_config config = {0};
+    enum gem_wine_status status;
+
+    if (!is_x86_64_guest() || !gem_process || !module || !image_size ||
+        !syscall_boundary || !unix_call_boundary) return STATUS_INVALID_PARAMETER;
+    config.version = GEM_WINE_X86_64_CONFIG_VERSION;
+    config.struct_size = sizeof(config);
+    config.loaded_base = (uint64_t)(uintptr_t)module;
+    config.image_size = image_size;
+    config.windows_syscall_boundary = (uint64_t)(uintptr_t)syscall_boundary;
+    config.unix_call_boundary = (uint64_t)(uintptr_t)unix_call_boundary;
+    status = gem_wine_process_prepare_x86_64(gem_process, &config);
+    if (status == GEM_WINE_OK)
+        TRACE("pure AMD64 routing enabled module=%p size=%lx syscall=%p unix=%p\n",
+              module, image_size, syscall_boundary, unix_call_boundary);
+    return gem_status(status);
+}
+
 void gem_process_init(void)
 {
     struct gem_wine_process_config config = {0};
@@ -363,6 +384,11 @@ BOOL gem_lifecycle_probe(void)
 
 void gem_process_init(void) {}
 void gem_prepare_arm64ec(void) {}
+NTSTATUS gem_prepare_x86_64(void *module, SIZE_T image_size,
+                            void *syscall_boundary, void *unix_call_boundary)
+{
+    return STATUS_NOT_SUPPORTED;
+}
 NTSTATUS gem_thread_init(struct thread_data *data) { return STATUS_SUCCESS; }
 void gem_thread_shutdown(struct thread_data *data) {}
 void gem_process_shutdown(struct thread_data *data) {}
