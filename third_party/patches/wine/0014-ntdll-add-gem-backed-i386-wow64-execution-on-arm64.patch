             MEM_ADDRESS_REQUIREMENTS *r = parameters[i].Pointer;
             ULONG_PTR limit;

-            if (is_wow64()) limit = get_wow_user_space_limit();
+            if (use_i386_shadow()) limit = i386_shadow_addr( get_wow_user_space_limit() );
+            else if (is_wow64()) limit = get_wow_user_space_limit();
             else limit = (ULONG_PTR)user_space_limit;

             if (r->Alignment)
@@ -5620,6 +5671,9 @@ NTSTATUS WINAPI NtAllocateVirtualMemoryEx( HANDLE process, PVOID *ret, SIZE_T *s
         return result.virtual_alloc_ex.status;
     }

+    if (use_i386_shadow() && !*ret && limit_high && !limit_low)
