+#include <stdint.h>
+#include <stdlib.h>
+#include <string.h>
+#include "ntstatus.h"
+#define WIN32_NO_STATUS
+#include "windef.h"
+#include "winnt.h"
+#include "winternl.h"
+#include "wine/unixlib.h"
+#include "wine/debug.h"
+#include <metalsharp/gem/wine_bridge.h>
+#include "unixlib.h"
+
+WINE_DEFAULT_DEBUG_CHANNEL(xtajit);
+
+static struct gem_wine_process *process;
+static pthread_mutex_t process_lock = PTHREAD_MUTEX_INITIALIZER;
+
+struct thread_entry
+{
+    struct thread_entry *next;
+    TEB32 *teb;
+    struct gem_wine_thread *thread;
+};
+static struct thread_entry *threads;
+static pthread_mutex_t thread_lock = PTHREAD_MUTEX_INITIALIZER;
+static struct gem_wine_thread *primary_thread;
+static void *canonical_ntdll_guard;
+static SIZE_T canonical_ntdll_guard_size;
+
+struct reservation
+{
+    struct reservation *next;
+    ULONG address;
+    ULONG size;
+};
+
+static struct reservation *reservations;
+static pthread_mutex_t memory_lock = PTHREAD_MUTEX_INITIALIZER;
+
+static struct reservation *find_reservation( ULONG address, ULONG size )
+{
+    struct reservation *entry;
+    uint64_t end = (uint64_t)address + size;
+    for (entry = reservations; entry; entry = entry->next)
+        if (address >= entry->address && end <= (uint64_t)entry->address + entry->size) return entry;
+    return NULL;
+}
+
+static NTSTATUS add_reservation( ULONG address, ULONG size )
+{
+    struct reservation *entry;
+    enum gem_wine_status status;
+    if (!size || (uint64_t)address + size > UINT64_C(0x100000000)) return STATUS_INVALID_PARAMETER;
+    if (find_reservation( address, size )) return STATUS_SUCCESS;
+    status = gem_wine_process_reserve( process, address, size );
+    if (status != GEM_WINE_OK) return status == GEM_WINE_CONFLICT ? STATUS_CONFLICTING_ADDRESSES : STATUS_UNSUCCESSFUL;
+    if (!(entry = malloc( sizeof(*entry) )))
+    {
+        gem_wine_process_release( process, address, size );
+        return STATUS_NO_MEMORY;
+    }
+    entry->address = address;
+    entry->size = size;
+    entry->next = reservations;
+    reservations = entry;
+    return STATUS_SUCCESS;
+}
+
+static void free_reservations(void)
+{
+    struct reservation *entry;
+    while ((entry = reservations))
+    {
+        reservations = entry->next;
+        free( entry );
+    }
+}
+
+static TEB32 *current_teb32(void)
+{
+    TEB *teb = NtCurrentTeb();
+    return (TEB32 *)((char *)teb + teb->WowTebOffset);
+}
+
+static ULONG protection_to_gem( ULONG protection )
+{
+    return protection & 0x1ff;
+}
+
+static NTSTATUS seed_i386_shadow(void)
+{
+    const ULONG_PTR shadow = 0x8000000000ull;
+    const ULONG_PTR shadow_end = shadow + 0x100000000ull;
+    ULONG_PTR cursor = shadow;
+
+    while (cursor < shadow_end)
+    {
+        MEMORY_BASIC_INFORMATION mbi;
+        SIZE_T ret_len;
+        ULONG_PTR allocation, allocation_end, scan;
+        NTSTATUS status = NtQueryVirtualMemory( NtCurrentProcess(), (void *)cursor,
+                                                MemoryBasicInformation, &mbi, sizeof(mbi), &ret_len );
+        if (status) return status;
+        if (!mbi.RegionSize) return STATUS_UNSUCCESSFUL;
+        if (mbi.State == MEM_FREE)
+        {
+            cursor = (ULONG_PTR)mbi.BaseAddress + mbi.RegionSize;
+            continue;
+        }
+
+        allocation = (ULONG_PTR)mbi.AllocationBase;
+        allocation_end = (ULONG_PTR)mbi.BaseAddress + mbi.RegionSize;
+        scan = allocation_end;
+        while (scan < shadow_end)
+        {
+            MEMORY_BASIC_INFORMATION next;
+            if (NtQueryVirtualMemory( NtCurrentProcess(), (void *)scan, MemoryBasicInformation,
+                                      &next, sizeof(next), &ret_len ) ||
+                (ULONG_PTR)next.AllocationBase != allocation || !next.RegionSize) break;
+            allocation_end = (ULONG_PTR)next.BaseAddress + next.RegionSize;
+            scan = allocation_end;
+        }
+
+        if (!find_reservation( (ULONG)(allocation - shadow), allocation_end - allocation ))
+        {
+            status = add_reservation( (ULONG)(allocation - shadow), allocation_end - allocation );
+            if (status) return status;
+            for (scan = allocation; scan < allocation_end; )
+            {
+                MEMORY_BASIC_INFORMATION region;
+                status = NtQueryVirtualMemory( NtCurrentProcess(), (void *)scan,
+                                               MemoryBasicInformation, &region, sizeof(region), &ret_len );
+                if (status || !region.RegionSize) return status ? status : STATUS_UNSUCCESSFUL;
+                if (region.State == MEM_COMMIT &&
+                    gem_wine_process_commit_i386_host( process, (ULONG)(scan - shadow),
+                                                       (void *)scan, region.RegionSize,
+                                                       protection_to_gem( region.Protect ) ) != GEM_WINE_OK)
+                    return STATUS_UNSUCCESSFUL;
+                scan = (ULONG_PTR)region.BaseAddress + region.RegionSize;
+            }
+        }
+        cursor = allocation_end;
+    }
+    return STATUS_SUCCESS;
+}
+
+static USHORT fpux_tag_to_full( const XSAVE_FORMAT *xsave )
+{
+    USHORT full = 0;
+    unsigned int i, tag, top = (xsave->StatusWord >> 11) & 7;
+    for (i = 0; i < 8; ++i)
+    {
+        const M128A *reg = &xsave->FloatRegisters[(i - top) & 7];
+        if (!(xsave->TagWord & (1u << i))) tag = 3;
+        else if ((reg->High & 0x7fff) == 0x7fff) tag = 2;
+        else if (!(reg->High & 0x7fff)) tag = reg->Low ? 2 : 1;
+        else tag = reg->Low >> 63 ? 0 : 2;
+        full |= tag << (2 * i);
+    }
+    return full;
+}
+
+static BYTE full_tag_to_fpux( USHORT full )
+{
+    BYTE abridged = 0;
+    unsigned int i;
+    for (i = 0; i < 8; ++i) if (((full >> (2 * i)) & 3) != 3) abridged |= 1u << i;
+    return abridged;
+}
+
+static void context_to_gem( struct gem_i386_context *dst, const I386_CONTEXT *src, ULONG teb )
+{
+    memset( dst, 0, sizeof(*dst) );
+    dst->layout_version = GEM_I386_CONTEXT_LAYOUT_VERSION;
+    dst->context_size = sizeof(*dst);
+    dst->teb = teb;
+    dst->mxcsr = 0x1f80;
+    dst->fcw = 0x37f;
+    dst->gpr[GEM_I386_EAX] = src->Eax; dst->gpr[GEM_I386_ECX] = src->Ecx;
+    dst->gpr[GEM_I386_EDX] = src->Edx; dst->gpr[GEM_I386_EBX] = src->Ebx;
+    dst->gpr[GEM_I386_ESP] = src->Esp; dst->gpr[GEM_I386_EBP] = src->Ebp;
+    dst->gpr[GEM_I386_ESI] = src->Esi; dst->gpr[GEM_I386_EDI] = src->Edi;
+    dst->eip = src->Eip; dst->eflags = src->EFlags | GEM_I386_EFLAGS_REQUIRED;
+    dst->segment[GEM_I386_ES] = src->SegEs; dst->segment[GEM_I386_CS] = src->SegCs;
+    dst->segment[GEM_I386_SS] = src->SegSs; dst->segment[GEM_I386_DS] = src->SegDs;
+    dst->segment[GEM_I386_FS] = src->SegFs; dst->segment[GEM_I386_GS] = src->SegGs;
+    dst->segment_base[GEM_I386_FS] = dst->teb;
+    dst->segment_limit[GEM_I386_ES] = dst->segment_limit[GEM_I386_CS] = 0xffffffff;
+    dst->segment_limit[GEM_I386_SS] = dst->segment_limit[GEM_I386_DS] = 0xffffffff;
+    dst->segment_limit[GEM_I386_FS] = dst->segment_limit[GEM_I386_GS] = 0xffffffff;
+    {
+        const XSAVE_FORMAT *xsave = (const XSAVE_FORMAT *)src->ExtendedRegisters;
+        unsigned int i;
+        dst->mxcsr = xsave->MxCsr;
+        dst->fcw = xsave->ControlWord;
+        dst->fsw = xsave->StatusWord;
+        dst->ftw = fpux_tag_to_full( xsave );
+        memcpy( dst->xmm, xsave->XmmRegisters, sizeof(dst->xmm) );
+        for (i = 0; i < 8; ++i) memcpy( &dst->x87[i], &xsave->FloatRegisters[i], 10 );
+    }
+}
+
+static void context_from_gem( I386_CONTEXT *dst, const struct gem_i386_context *src )
+{
+    dst->Eax = src->gpr[GEM_I386_EAX]; dst->Ecx = src->gpr[GEM_I386_ECX];
+    dst->Edx = src->gpr[GEM_I386_EDX]; dst->Ebx = src->gpr[GEM_I386_EBX];
+    dst->Esp = src->gpr[GEM_I386_ESP]; dst->Ebp = src->gpr[GEM_I386_EBP];
+    dst->Esi = src->gpr[GEM_I386_ESI]; dst->Edi = src->gpr[GEM_I386_EDI];
+    dst->Eip = src->eip; dst->EFlags = src->eflags;
+    dst->SegEs = src->segment[GEM_I386_ES]; dst->SegCs = src->segment[GEM_I386_CS];
+    dst->SegSs = src->segment[GEM_I386_SS]; dst->SegDs = src->segment[GEM_I386_DS];
+    dst->SegFs = src->segment[GEM_I386_FS]; dst->SegGs = src->segment[GEM_I386_GS];
+    {
+        XSAVE_FORMAT *xsave = (XSAVE_FORMAT *)dst->ExtendedRegisters;
+        unsigned int i;
+        xsave->MxCsr = src->mxcsr;
+        xsave->ControlWord = src->fcw;
+        xsave->StatusWord = src->fsw;
+        xsave->TagWord = full_tag_to_fpux( src->ftw );
+        memcpy( xsave->XmmRegisters, src->xmm, sizeof(src->xmm) );
+        for (i = 0; i < 8; ++i) memcpy( &xsave->FloatRegisters[i], &src->x87[i], 10 );
+    }
+}
+
+static NTSTATUS process_init( void *args )
+{
+    const struct xtajit_process_init_params *params = args;
+    struct gem_wine_process_config config = {0};
+    enum gem_wine_status status;
+    NTSTATUS guard_status;
+    TRACE("unix process init guest=%08x host=%p size=%08x\n", params->ntdll_base,
+          (void *)(ULONG_PTR)params->ntdll_host, params->ntdll_size);
+    pthread_mutex_lock( &process_lock );
+    if (process) { pthread_mutex_unlock( &process_lock ); return STATUS_OBJECT_NAME_COLLISION; }
+    canonical_ntdll_guard = (void *)(UINT64_C(0x10000000000) + params->ntdll_base);
+    canonical_ntdll_guard_size = params->ntdll_size;
+    if ((guard_status = NtAllocateVirtualMemory( NtCurrentProcess(), &canonical_ntdll_guard, 0,
+                                                 &canonical_ntdll_guard_size, MEM_RESERVE,
+                                                 PAGE_NOACCESS )))
+    {
+        canonical_ntdll_guard = NULL;
+        canonical_ntdll_guard_size = 0;
+        pthread_mutex_unlock( &process_lock );
+        return guard_status;
+    }
+    config.version = GEM_WINE_PROCESS_CONFIG_VERSION;
+    config.struct_size = sizeof(config);
+    config.segment_instruction_budget = 100000;
+    config.total_instruction_budget = 1000000;
+    config.max_boundary_callbacks = 1;
+    config.host_return_sentinel = 0xfffffff0;
+    status = gem_wine_process_create( &config, &process );
+    if (status == GEM_WINE_OK)
+    {
+        struct gem_wine_i386_config i386 = {0};
+        NTSTATUS ntstatus;
+        pthread_mutex_lock( &memory_lock );
+        ntstatus = add_reservation( params->ntdll_base, params->ntdll_size );
+        if (!ntstatus && gem_wine_process_bind_kuser( process,
+                                                       (void *)UINT64_C(0x1007ffe0000) ) != GEM_WINE_OK)
+            ntstatus = STATUS_UNSUCCESSFUL;
+        if (!ntstatus && gem_wine_process_commit_i386_host( process, params->ntdll_base,
+                                                            (void *)(ULONG_PTR)params->ntdll_host,
+                                                            params->ntdll_size,
+                                                            GEM_WINE_PAGE_EXECUTE_READWRITE ) != GEM_WINE_OK)
+            ntstatus = STATUS_UNSUCCESSFUL;
+        pthread_mutex_unlock( &memory_lock );
+        i386.version = GEM_WINE_I386_CONFIG_VERSION;
+        i386.struct_size = sizeof(i386);
+        i386.loaded_base = params->ntdll_base;
+        i386.image_size = params->ntdll_size;
+        i386.windows_syscall_boundary = params->syscall_boundary;
+        i386.unix_call_boundary = params->unix_boundary;
+        i386.host_return_sentinel = 0xfffffff0;
+        i386.flags = 0;
+        if (!ntstatus && gem_wine_process_prepare_i386( process, &i386 ) != GEM_WINE_OK)
+            ntstatus = STATUS_INVALID_IMAGE_FORMAT;
+        if (!ntstatus) ntstatus = seed_i386_shadow();
+        if (ntstatus)
+        {
+            gem_wine_process_destroy( process );
+            process = NULL;
+            pthread_mutex_lock( &memory_lock );
+            free_reservations();
+            pthread_mutex_unlock( &memory_lock );
+            status = GEM_WINE_ENGINE_ERROR;
+        }
+    }
+    pthread_mutex_unlock( &process_lock );
+    return status == GEM_WINE_OK ? STATUS_SUCCESS : STATUS_DLL_INIT_FAILED;
+}
+
+static NTSTATUS process_term( void *args )
+{
+    enum gem_wine_status status;
+    pthread_mutex_lock( &process_lock );
+    status = process ? gem_wine_process_destroy( process ) : GEM_WINE_OK;
+    if (status == GEM_WINE_OK)
+    {
+        process = NULL;
+        pthread_mutex_lock( &memory_lock );
+        free_reservations();
+        pthread_mutex_unlock( &memory_lock );
+    }
+    pthread_mutex_unlock( &process_lock );
+    if (canonical_ntdll_guard)
+    {
+        SIZE_T size = 0;
+        NtFreeVirtualMemory( NtCurrentProcess(), &canonical_ntdll_guard, &size, MEM_RELEASE );
+        canonical_ntdll_guard = NULL;
+        canonical_ntdll_guard_size = 0;
+    }
+    return status == GEM_WINE_OK ? STATUS_SUCCESS : STATUS_UNSUCCESSFUL;
+}
+
+static NTSTATUS thread_init( void *args )
+{
+    struct gem_wine_i386_thread_config config = {0};
+    struct gem_wine_thread *thread;
+    TEB32 *teb;
+    ULONG stack_base, stack_limit, stack_reserve, teb_base;
+    enum gem_wine_status status;
+    NTSTATUS ntstatus;
+    struct thread_entry *entry;
+    teb = current_teb32();
+    TRACE("unix thread init teb=%p guest=%08x\n", teb, (ULONG)(ULONG_PTR)teb);
+    pthread_mutex_lock( &thread_lock );
+    if (primary_thread)
+    {
+        pthread_mutex_unlock( &thread_lock );
+        return STATUS_SUCCESS;
+    }
+    for (entry = threads; entry; entry = entry->next)
+        if (entry->teb == teb) break;
+    if (entry)
+    {
+        pthread_mutex_unlock( &thread_lock );
+        return STATUS_SUCCESS;
+    }
+    pthread_mutex_unlock( &thread_lock );
+
+    /* The initial WoW64 thread reaches the CPU DLL before Wine has populated
+     * its TEB32 stack fields on this host.  Install a canonical high-host
+     * stack whose low 32 bits remain valid guest addresses. */
+    if (!teb->Tib.StackBase)
+    {
+        void *host_stack = (void *)UINT64_C(0x1007fe00000);
+        SIZE_T host_stack_size = 0x100000;
+        ntstatus = NtAllocateVirtualMemory( NtCurrentProcess(), &host_stack, 0, &host_stack_size,
+                                            MEM_RESERVE | MEM_COMMIT, PAGE_READWRITE );
+        if (ntstatus) return ntstatus;
+        teb->DeallocationStack = 0x7fe00000;
+        teb->Tib.StackLimit = 0x7fe00000;
+        teb->Tib.StackBase = 0x7ff00000;
+    }
+    {
+        PEB32 *peb32 = NULL;
+        ntstatus = NtQueryInformationProcess( NtCurrentProcess(), ProcessWow64Information,
+                                              &peb32, sizeof(peb32), NULL );
+        if (ntstatus || !peb32) return ntstatus ? ntstatus : STATUS_UNSUCCESSFUL;
+        if (!teb->Peb) teb->Peb = (ULONG)(ULONG_PTR)peb32;
+    }
+    teb_base = (ULONG)(ULONG_PTR)teb & ~0x3fff;
+    stack_base = (ULONG)(ULONG_PTR)teb->Tib.StackBase;
+    stack_limit = (ULONG)(ULONG_PTR)teb->Tib.StackLimit;
+    stack_reserve = (ULONG)(ULONG_PTR)teb->DeallocationStack;
+    TRACE("i386 stack guest=%08x-%08x commit=%08x peb=%08x\n",
+          stack_reserve, stack_base, stack_limit, teb->Peb);
+    pthread_mutex_lock( &memory_lock );
+    ntstatus = add_reservation( teb_base, 0x8000 );
+    if (!ntstatus && gem_wine_process_commit_i386_host( process, teb_base,
+                                                        (void *)((ULONG_PTR)teb & ~0x3fffull),
+                                                        0x8000, GEM_WINE_PAGE_READWRITE ) != GEM_WINE_OK)
+        ntstatus = STATUS_UNSUCCESSFUL;
+    if (!ntstatus) ntstatus = add_reservation( stack_reserve, stack_base - stack_reserve );
+    if (!ntstatus && gem_wine_process_commit_i386_host( process, stack_limit,
+                                                        (void *)(0x10000000000ull + stack_limit),
+                                                        stack_base - stack_limit,
+                                                        GEM_WINE_PAGE_READWRITE ) != GEM_WINE_OK)
+        ntstatus = STATUS_UNSUCCESSFUL;
+    pthread_mutex_unlock( &memory_lock );
+    if (ntstatus)
+    {
+        TRACE("thread memory import failed status=%08x\n", ntstatus);
+        return ntstatus;
+    }
+    config.version = GEM_WINE_I386_THREAD_CONFIG_VERSION;
+    config.struct_size = sizeof(config);
+    config.teb = (ULONG)(ULONG_PTR)current_teb32();
+    status = gem_wine_i386_thread_create( process, &config, &thread );
+    TRACE("i386 thread create status=%u thread=%p\n", status, thread);
+    if (status == GEM_WINE_OK)
+    {
+        if (!(entry = malloc( sizeof(*entry) ))) return STATUS_NO_MEMORY;
+        entry->teb = teb;
+        entry->thread = thread;
+        pthread_mutex_lock( &thread_lock );
+        entry->next = threads;
+        threads = entry;
+        if (!primary_thread) primary_thread = thread;
+        pthread_mutex_unlock( &thread_lock );
+    }
+    return status == GEM_WINE_OK ? STATUS_SUCCESS : STATUS_UNSUCCESSFUL;
+}
+
+static NTSTATUS thread_term( void *args )
+{
+    struct thread_entry **cursor, *entry;
+    struct gem_wine_thread *thread = NULL;
+    TRACE("unix thread term teb=%p primary=%p\n", current_teb32(), primary_thread);
+    pthread_mutex_lock( &thread_lock );
+    for (cursor = &threads; (entry = *cursor); cursor = &entry->next)
+        if (entry->teb == current_teb32()) break;
+    if (entry)
+    {
+        *cursor = entry->next;
+        thread = entry->thread;
+        free( entry );
+    }
+    pthread_mutex_unlock( &thread_lock );
+    if (thread && gem_wine_thread_destroy( thread ) != GEM_WINE_OK) return STATUS_UNSUCCESSFUL;
+    return STATUS_SUCCESS;
+}
+
+static BOOL protection_allows( ULONG protection, ULONG access )
+{
+    protection &= 0xff;
+    if (access == GEM_WINE_ACCESS_FETCH)
+        return protection == PAGE_EXECUTE || protection == PAGE_EXECUTE_READ ||
+               protection == PAGE_EXECUTE_READWRITE || protection == PAGE_EXECUTE_WRITECOPY;
+    if (access == GEM_WINE_ACCESS_WRITE)
+        return protection == PAGE_READWRITE || protection == PAGE_WRITECOPY ||
+               protection == PAGE_EXECUTE_READWRITE || protection == PAGE_EXECUTE_WRITECOPY;
+    return protection != PAGE_NOACCESS && protection != PAGE_EXECUTE;
+}
+
+static NTSTATUS sync_shadow_fault( ULONG address, ULONG access )
+{
+    ULONG_PTR shadow = address >= 0x7f000000 ? 0x10000000000ull : 0x8000000000ull;
+    const ULONG page = address & ~0xfffU;
+    MEMORY_BASIC_INFORMATION mbi;
+    SIZE_T ret_len;
+    enum gem_wine_status status;
+    uint32_t old_protection;
+    NTSTATUS ntstatus;
+
+    ntstatus = NtQueryVirtualMemory( NtCurrentProcess(), (void *)(shadow + page),
+                                     MemoryBasicInformation, &mbi, sizeof(mbi), &ret_len );
+    if (!ntstatus && mbi.State != MEM_COMMIT)
+    {
+        ULONG_PTR alternate = shadow == 0x8000000000ull ? 0x10000000000ull : 0x8000000000ull;
+        MEMORY_BASIC_INFORMATION alternate_mbi;
+        if (!NtQueryVirtualMemory( NtCurrentProcess(), (void *)(alternate + page),
+                                   MemoryBasicInformation, &alternate_mbi,
+                                   sizeof(alternate_mbi), &ret_len ) &&
+            alternate_mbi.State == MEM_COMMIT)
+        {
+            shadow = alternate;
+            mbi = alternate_mbi;
+        }
+    }
+    if (ntstatus || mbi.State != MEM_COMMIT || !protection_allows( mbi.Protect, access ))
+        return STATUS_ACCESS_VIOLATION;
+    pthread_mutex_lock( &memory_lock );
+    status = gem_wine_process_protect( process, page, 0x1000,
+                                       protection_to_gem( mbi.Protect ), &old_protection );
+    if (status != GEM_WINE_OK)
+    {
+        if (!find_reservation( page, 0x1000 ))
+        {
+            ntstatus = add_reservation( page, 0x1000 );
+            if (ntstatus)
+            {
+                pthread_mutex_unlock( &memory_lock );
+                return ntstatus;
+            }
+        }
+        status = gem_wine_process_commit_i386_host( process, page, (void *)(shadow + page),
+                                                     0x1000, protection_to_gem( mbi.Protect ) );
+    }
+    if (status == GEM_WINE_OK)
+        status = gem_wine_process_invalidate_code( process, page, 0x1000 );
+    pthread_mutex_unlock( &memory_lock );
+    return status == GEM_WINE_OK ? STATUS_SUCCESS : STATUS_UNSUCCESSFUL;
+}
+
+static NTSTATUS run( void *args )
+{
+    struct xtajit_run_params *params = args;
+    struct gem_wine_thread *thread = NULL;
+    struct thread_entry *entry;
+    struct gem_i386_context input, output;
+    struct gem_wine_run_result result;
+    enum gem_wine_status status;
+    unsigned int retry;
+    pthread_mutex_lock( &thread_lock );
+    thread = primary_thread;
+    for (entry = threads; entry; entry = entry->next)
+        if (entry->teb == current_teb32()) { thread = entry->thread; break; }
+    pthread_mutex_unlock( &thread_lock );
+    if (!thread && thread_init( NULL )) return STATUS_UNSUCCESSFUL;
+    if (!thread)
+    {
+        pthread_mutex_lock( &thread_lock );
+        for (entry = threads; entry; entry = entry->next)
+            if (entry->teb == current_teb32()) { thread = entry->thread; break; }
+        pthread_mutex_unlock( &thread_lock );
+    }
+    context_to_gem( &input, &params->context, params->teb );
+    TRACE("run input layout=%u size=%u teb=%08x eip=%08x esp=%08x flags=%08x stop=%u thread=%p\n",
+          input.layout_version, input.context_size, input.teb, input.eip,
+          input.gpr[GEM_I386_ESP], input.eflags, input.stop_reason, thread);
+    for (retry = 0; ; ++retry)
+    {
+        status = gem_wine_i386_thread_run( thread, &input, &output, &result );
+        if (retry >= 255 || status != GEM_WINE_STOPPED ||
+            result.last_event != GEM_WINE_EVENT_MEMORY_FAULT ||
+            sync_shadow_fault( result.stop.fault_address, result.stop.access ))
+            break;
+        input = output;
+        input.stop_reason = GEM_STOP_NONE;
+    }
+    TRACE("run status=%u outcome=%u event=%u eip=%08x fault=%08llx access=%u\n",
+          status, result.outcome, result.last_event, output.eip,
+          (unsigned long long)result.stop.fault_address, result.stop.access);
+    context_from_gem( &params->context, &output );
+    params->status = status == GEM_WINE_OK || status == GEM_WINE_STOPPED ? STATUS_SUCCESS :
+                     status == GEM_WINE_BUDGET_EXPIRED ? STATUS_TIMEOUT : STATUS_UNSUCCESSFUL;
+    params->outcome = result.outcome;
+    params->event = result.last_event;
+    params->engine_status = result.stop.engine_status;
+    params->fault_address = result.stop.fault_address;
+    params->fault_access = result.stop.access;
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS map( void *args )
+{
+    struct xtajit_memory_params *params = args;
+    enum gem_wine_status status;
+    NTSTATUS ntstatus;
+    pthread_mutex_lock( &memory_lock );
+    ntstatus = add_reservation( params->address, params->size );
+    if (ntstatus || params->operation == xtajit_memory_reserve)
+    {
+        pthread_mutex_unlock( &memory_lock );
+        return ntstatus;
+    }
+    status = gem_wine_process_commit_i386_host( process, params->address,
+                                                (void *)(ULONG_PTR)params->host, params->size,
+                                                protection_to_gem(params->protection) );
+    if (status != GEM_WINE_OK)
+    {
+        pthread_mutex_unlock( &memory_lock );
+        return STATUS_UNSUCCESSFUL;
+    }
+    pthread_mutex_unlock( &memory_lock );
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS decommit( void *args )
+{
+    struct xtajit_memory_params *p = args;
+    if (gem_wine_process_invalidate_code( process, p->address, p->size ) != GEM_WINE_OK)
+        return STATUS_UNSUCCESSFUL;
+    return gem_wine_process_decommit(process, p->address, p->size) == GEM_WINE_OK ? STATUS_SUCCESS : STATUS_UNSUCCESSFUL;
+}
+static NTSTATUS release( void *args )
+{
+    struct xtajit_memory_params *p = args;
+    struct reservation **cursor, *entry;
+    enum gem_wine_status status;
+    pthread_mutex_lock( &memory_lock );
+    for (cursor = &reservations; (entry = *cursor); cursor = &entry->next)
+        if (entry->address == p->address) break;
+    if (!entry)
+    {
+        pthread_mutex_unlock( &memory_lock );
+        return STATUS_MEMORY_NOT_ALLOCATED;
+    }
+    if (gem_wine_process_invalidate_code( process, entry->address, entry->size ) != GEM_WINE_OK)
+    {
+        pthread_mutex_unlock( &memory_lock );
+        return STATUS_UNSUCCESSFUL;
+    }
+    status = gem_wine_process_release( process, entry->address, entry->size );
+    if (status == GEM_WINE_OK)
+    {
+        *cursor = entry->next;
+        free( entry );
+    }
+    pthread_mutex_unlock( &memory_lock );
+    return status == GEM_WINE_OK ? STATUS_SUCCESS : STATUS_UNSUCCESSFUL;
+}
+static NTSTATUS protect( void *args )
+{
+    struct xtajit_memory_params *p = args;
+    NTSTATUS status;
+    if (gem_wine_process_invalidate_code( process, p->address, p->size ) != GEM_WINE_OK)
+        return STATUS_UNSUCCESSFUL;
+    status = gem_wine_process_protect(process, p->address, p->size,
+                                      protection_to_gem(p->protection), &p->old_protection) ==
+                     GEM_WINE_OK
+                 ? STATUS_SUCCESS
+                 : STATUS_UNSUCCESSFUL;
+    return status;
+}
+static NTSTATUS invalidate( void *args )
+{
+    struct xtajit_memory_params *p = args;
+    return gem_wine_process_invalidate_code(process, p->address, p->size) == GEM_WINE_OK ? STATUS_SUCCESS : STATUS_UNSUCCESSFUL;
+}
+
+const unixlib_entry_t __wine_unix_call_funcs[] =
+{
+    process_init, process_term, thread_init, thread_term, run, map, decommit, release, protect, invalidate
+};
+C_ASSERT( ARRAY_SIZE(__wine_unix_call_funcs) == unix_funcs_count );
