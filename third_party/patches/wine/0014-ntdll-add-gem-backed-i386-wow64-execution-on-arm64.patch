+
     return allocate_virtual_memory( ret, size_ptr, type, protect,
                                     limit_low, limit_high, align, attributes );
 }
@@ -6563,6 +6617,11 @@ NTSTATUS WINAPI NtMapViewOfSection( HANDLE handle, HANDLE process, PVOID *addr_p
         return result.map_view.status;
     }

+    if (use_i386_shadow() && !*addr_ptr && zero_bits)
