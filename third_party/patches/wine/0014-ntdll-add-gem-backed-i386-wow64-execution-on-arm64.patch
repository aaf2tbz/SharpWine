diff --git a/dlls/xtajit/cpu.c b/dlls/xtajit/cpu.c
new file mode 100644
index 0000000000..79ef5f0a3f
--- /dev/null
+++ b/dlls/xtajit/cpu.c
@@ -0,0 +1,292 @@
+/* Wine WoW64 i386 execution through the native ARM64 GEM bridge. */
+
+#include <stdarg.h>
+
+#include "ntstatus.h"
+#define WIN32_NO_STATUS
+#include "windef.h"
+#include "winbase.h"
+#include "winternl.h"
+#include "wine/debug.h"
+#include "wine/unixlib.h"
+#include "unixlib.h"
+
+WINE_DEFAULT_DEBUG_CHANNEL(xtajit);
+
+extern NTSTATUS WINAPI Wow64SystemServiceEx( UINT num, UINT *args );
+extern NTSTATUS WINAPI Wow64RaiseException( int code, EXCEPTION_RECORD *rec );
+extern void WINAPI Wow64ProcessPendingCrossProcessItems(void);
+
+static ULONG syscall_boundary;
+static ULONG unix_boundary;
+
+static inline void *i386_guest_ptr( ULONG address )
+{
+    if (address >= 0x7f000000) return (void *)((ULONG_PTR)0x10000000000ull + address);
+    return (void *)((ULONG_PTR)0x8000000000ull + address);
+}
+
+BOOL WINAPI DllMain( HINSTANCE instance, DWORD reason, void *reserved )
+{
+    if (reason == DLL_PROCESS_ATTACH)
+    {
+        LdrDisableThreadCalloutsForDll( instance );
+        if (__wine_init_unix_call()) return FALSE;
+    }
+    return TRUE;
+}
+
+static ULONG page_protection( ULONG protection )
+{
+    return protection & 0x1ff;
+}
+
+NTSTATUS WINAPI BTCpuProcessInit(void)
+{
+    struct xtajit_process_init_params params = {0};
+    static const WCHAR ntdllW[] = L"ntdll.dll";
+    SYSTEM_DLL_INIT_BLOCK *init_block;
+    UNICODE_STRING name = RTL_CONSTANT_STRING( ntdllW );
+    HMODULE module;
+    const IMAGE_DOS_HEADER *dos;
+    const IMAGE_NT_HEADERS32 *nt;
+    ULONG_PTR ntdll_host;
+    TRACE("process init start\n");
+    if (LdrGetDllHandle( NULL, 0, &name, &module )) return STATUS_DLL_NOT_FOUND;
+    if (!(init_block = RtlFindExportedRoutineByName( module, "LdrSystemDllInitBlock" )))
+        return STATUS_PROCEDURE_NOT_FOUND;
+    ntdll_host = (ULONG_PTR)init_block->ntdll_handle;
+    params.ntdll_base = PtrToUlong( (void *)ntdll_host );
+    if (ntdll_host <= MAXDWORD) ntdll_host += (ULONG_PTR)0x8000000000ull;
+    dos = (const IMAGE_DOS_HEADER *)ntdll_host;
+    TRACE("i386 ntdll guest=%08lx host=%p\n", params.ntdll_base, dos);
+    if (!dos || dos->e_magic != IMAGE_DOS_SIGNATURE) return STATUS_INVALID_IMAGE_FORMAT;
+    nt = (const IMAGE_NT_HEADERS32 *)((const char *)dos + dos->e_lfanew);
+    if (nt->Signature != IMAGE_NT_SIGNATURE || nt->FileHeader.Machine != IMAGE_FILE_MACHINE_I386)
+        return STATUS_INVALID_IMAGE_FORMAT;
+    params.syscall_boundary = 0x7ffe1000;
+    params.unix_boundary = 0x7ffe1010;
+    params.ntdll_size = nt->OptionalHeader.SizeOfImage;
+    params.ntdll_host = (ULONG_PTR)dos;
+    syscall_boundary = params.syscall_boundary;
+    unix_boundary = params.unix_boundary;
+    TRACE("calling unix process init image_size=%08lx\n", params.ntdll_size);
+    return WINE_UNIX_CALL( unix_process_init, &params );
+}
+
+void WINAPI BTCpuProcessTerm( HANDLE process, BOOL post, NTSTATUS status )
+{
+    if (post) WINE_UNIX_CALL( unix_process_term, NULL );
+}
+
+NTSTATUS WINAPI BTCpuThreadInit(void)
+{
+    I386_CONTEXT context = { CONTEXT_I386_CONTROL };
+    TEB32 *teb = (TEB32 *)((char *)NtCurrentTeb() + NtCurrentTeb()->WowTebOffset);
+    NTSTATUS status;
+
+    TRACE("thread init\n");
+    if ((status = WINE_UNIX_CALL( unix_thread_init, NULL ))) return status;
+
+    /* The ARM64 signal context is initialized before the high i386 stack has
+     * been installed on Apple Silicon.  Refresh a stale bootstrap ESP now that
+     * the canonical WoW64 stack exists; wow64!thread_init will build the real
+     * startup frame immediately after this callback. */
+    status = RtlWow64GetThreadContext( GetCurrentThread(), &context );
+    TRACE("thread context status=%08lx esp=%08lx stack=%08lx-%08lx\n", status, context.Esp,
+          teb->DeallocationStack, teb->Tib.StackBase);
+    if (!status &&
+        (context.Esp < teb->DeallocationStack || context.Esp > teb->Tib.StackBase))
+    {
+        context.Esp = teb->Tib.StackBase - 16;
+        status = RtlWow64SetThreadContext( GetCurrentThread(), &context );
+        TRACE("refreshed thread esp=%08lx status=%08lx\n", context.Esp, status);
+    }
+    return status;
+}
+
+void WINAPI BTCpuThreadTerm( HANDLE thread, LONG exit_code )
+{
+    WINE_UNIX_CALL( unix_thread_term, NULL );
+}
+
+void * WINAPI BTCpuGetBopCode(void)
+{
+    return ULongToPtr( syscall_boundary );
+}
+
+void * WINAPI __wine_get_unix_opcode(void)
+{
+    return ULongToPtr( unix_boundary );
+}
+
+NTSTATUS WINAPI BTCpuGetContext( HANDLE thread, HANDLE process, void *unknown, I386_CONTEXT *context )
+{
+    return RtlWow64GetThreadContext( thread, context );
+}
+
+NTSTATUS WINAPI BTCpuSetContext( HANDLE thread, HANDLE process, void *unknown,
+                                 I386_CONTEXT *context )
+{
+    return RtlWow64SetThreadContext( thread, context );
+}
+
+void WINAPI BTCpuSimulate(void)
+{
+    struct xtajit_run_params params = {{0}};
+    params.context.ContextFlags = CONTEXT_I386_ALL;
+    if (RtlWow64GetThreadContext( GetCurrentThread(), &params.context ))
+        RtlRaiseStatus( STATUS_UNSUCCESSFUL );
+    for (;;)
+    {
+        UINT *stack;
+        TEB *native_teb = NtCurrentTeb();
+        params.teb = (ULONG)(ULONG_PTR)((char *)native_teb + native_teb->WowTebOffset);
+        params.status = params.outcome = params.event = 0;
+        if (WINE_UNIX_CALL( unix_run, &params )) RtlRaiseStatus( STATUS_UNSUCCESSFUL );
+        RtlWow64SetThreadContext( GetCurrentThread(), &params.context );
+        if (params.status == STATUS_TIMEOUT)
+        {
+            NtYieldExecution();
+            continue;
+        }
+        if (params.status) RtlRaiseStatus( params.status );
+        if (params.outcome == 1) return;
+        stack = i386_guest_ptr( params.context.Esp );
+        if (params.event == 1)
+        {
+            I386_CONTEXT continued = {0};
+            NTSTATUS syscall_status;
+            TRACE("syscall num=%08lx eip=%08lx esp=%08lx stack=%08x,%08x,%08x\n",
+                  params.context.Eax, params.context.Eip, params.context.Esp,
+                  stack[0], stack[1], stack[2]);
+            /* The BOP CALL pushes the CPU-stub return address in front of the
+             * caller return address; syscall arguments start two words in. */
+            syscall_status = Wow64SystemServiceEx( params.context.Eax, stack + 2 );
+            continued.ContextFlags = CONTEXT_I386_ALL;
+            if (!RtlWow64GetThreadContext( GetCurrentThread(), &continued ) &&
+                (continued.Eip != params.context.Eip || continued.Esp != params.context.Esp))
+            {
+                params.context = continued;
+                continue;
+            }
+            params.context.Eax = syscall_status;
+            TRACE("syscall result=%08lx return=%08x\n", params.context.Eax, *stack);
+            params.context.Eip = *stack;
+            params.context.Esp += sizeof(*stack);
+            continue;
+        }
+        if (params.event == 2)
+        {
+            ULONG64 handle;
+            memcpy( &handle, stack + 1, sizeof(handle) );
+            params.context.Eax = __wine_unix_call_dispatcher( handle, stack[3], i386_guest_ptr(stack[4]) );
+            params.context.Eip = *stack;
+            params.context.Esp += 5 * sizeof(*stack);
+            continue;
+        }
+        if (params.event == 6)
+        {
+            Wow64ProcessPendingCrossProcessItems();
+            continue;
+        }
+        {
+            EXCEPTION_RECORD rec = {0};
+            rec.ExceptionAddress = i386_guest_ptr( params.context.Eip );
+            if (params.event == 3)
+            {
+                rec.ExceptionCode = EXCEPTION_ACCESS_VIOLATION;
+                rec.NumberParameters = 2;
+                rec.ExceptionInformation[0] = params.fault_access == 3 ? 1 :
+                                              params.fault_access == 1 ? 8 : 0;
+                rec.ExceptionInformation[1] = params.fault_address;
+                Wow64RaiseException( -1, &rec );
+            }
+            else if (params.event == 4) Wow64RaiseException( 3, &rec );
+            else Wow64RaiseException( 6, &rec );
+            if (RtlWow64GetThreadContext( GetCurrentThread(), &params.context ))
+                RtlRaiseStatus( STATUS_UNSUCCESSFUL );
+        }
+    }
+}
+
+BOOLEAN WINAPI BTCpuIsProcessorFeaturePresent( UINT feature )
+{
+    static const ULONGLONG features = (1ull << PF_MMX_INSTRUCTIONS_AVAILABLE) |
+        (1ull << PF_XMMI_INSTRUCTIONS_AVAILABLE) | (1ull << PF_XMMI64_INSTRUCTIONS_AVAILABLE) |
+        (1ull << PF_SSE3_INSTRUCTIONS_AVAILABLE) | (1ull << PF_NX_ENABLED);
+    return feature < 64 && (features & (1ull << feature));
+}
+
+void WINAPI BTCpuNotifyMemoryAlloc( void *addr, SIZE_T size, ULONG type, ULONG protection,
+                                    BOOL post, NTSTATUS status )
+{
+    struct xtajit_memory_params params = {0};
+    if (!post || status || !(type & (MEM_RESERVE | MEM_COMMIT))) return;
+    params.address = PtrToUlong( addr );
+    params.size = size;
+    params.protection = page_protection( protection );
+    params.operation = (type & MEM_COMMIT) ? xtajit_memory_commit : xtajit_memory_reserve;
+    params.host = (ULONG_PTR)addr;
+    WINE_UNIX_CALL( unix_map, &params );
+}
+
+NTSTATUS WINAPI BTCpuNotifyMapViewOfSection( void *unk1, void *addr, void *unk2, SIZE_T size,
+                                             ULONG type, ULONG protection )
+{
+    struct xtajit_memory_params params = {0};
+    params.address = PtrToUlong( addr );
+    params.size = size;
+    params.protection = page_protection( protection );
+    params.operation = xtajit_memory_map_section;
+    params.host = (ULONG_PTR)addr;
+    return WINE_UNIX_CALL( unix_map, &params );
+}
+
+void WINAPI BTCpuNotifyMemoryFree( void *addr, SIZE_T size, ULONG type, BOOL post, NTSTATUS status )
+{
+    struct xtajit_memory_params params = {PtrToUlong(addr), size};
+    if (!post || status) return;
+    WINE_UNIX_CALL( (type & MEM_RELEASE) ? unix_release : unix_decommit, &params );
+}
+
+void WINAPI BTCpuNotifyUnmapViewOfSection( void *addr, BOOL post, NTSTATUS status )
+{
+    struct xtajit_memory_params params = {PtrToUlong(addr)};
+    if (!post || status) return;
+    WINE_UNIX_CALL( unix_release, &params );
+}
+
+void WINAPI BTCpuNotifyMemoryProtect( void *addr, SIZE_T size, ULONG protection,
+                                      BOOL post, NTSTATUS status )
+{
+    struct xtajit_memory_params params = {PtrToUlong(addr), size, page_protection(protection)};
+    if (!post || status) return;
+    WINE_UNIX_CALL( unix_protect, &params );
+}
+
+void WINAPI BTCpuFlushInstructionCache2( const void *addr, SIZE_T size )
+{
+    struct xtajit_memory_params params = {PtrToUlong(addr), size};
+    WINE_UNIX_CALL( unix_invalidate, &params );
+}
+void WINAPI BTCpuFlushInstructionCacheHeavy( const void *addr, SIZE_T size )
+{
+    BTCpuFlushInstructionCache2( addr, size );
+}
+void WINAPI BTCpuNotifyMemoryDirty( void *addr, SIZE_T size )
+{
+    BTCpuFlushInstructionCache2( addr, size );
+}
+void WINAPI BTCpuNotifyReadFile( HANDLE handle, void *addr, SIZE_T size, BOOL post, NTSTATUS status )
+{
+    if (post && !status) BTCpuFlushInstructionCache2( addr, size );
+}
+NTSTATUS WINAPI BTCpuResetToConsistentState( EXCEPTION_POINTERS *ptrs ) { return STATUS_SUCCESS; }
+NTSTATUS WINAPI BTCpuTurboThunkControl( ULONG enable ) { return enable ? STATUS_NOT_SUPPORTED : STATUS_SUCCESS; }
+void WINAPI BTCpuUpdateProcessorInformation( SYSTEM_CPU_INFORMATION *info )
+{
+    info->ProcessorArchitecture = PROCESSOR_ARCHITECTURE_INTEL;
+    info->ProcessorLevel = 6;
+    info->ProcessorRevision = 0x3a09;
+}
