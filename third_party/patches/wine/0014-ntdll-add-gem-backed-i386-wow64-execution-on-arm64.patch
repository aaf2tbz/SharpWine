+/* Native ARM64 GEM_i386 Unix-call contract. */
+#ifndef __WINE_XTAJIT_UNIXLIB_H
+#define __WINE_XTAJIT_UNIXLIB_H
+
+#include "windef.h"
+#include "winnt.h"
+
+enum xtajit_unix_call
+{
+    unix_process_init,
+    unix_process_term,
+    unix_thread_init,
+    unix_thread_term,
+    unix_run,
+    unix_map,
+    unix_decommit,
+    unix_release,
+    unix_protect,
+    unix_invalidate,
+    unix_funcs_count
+};
+
+enum xtajit_memory_operation
+{
+    xtajit_memory_reserve = 1,
+    xtajit_memory_commit,
+    xtajit_memory_map_section
+};
+
+struct xtajit_process_init_params
+{
+    ULONG syscall_boundary;
+    ULONG unix_boundary;
+    ULONG ntdll_base;
+    ULONG ntdll_size;
+    ULONG_PTR ntdll_host;
+};
+
+struct xtajit_run_params
+{
+    I386_CONTEXT context;
+    ULONG teb;
+    ULONG status;
+    ULONG outcome;
+    ULONG event;
+    ULONG engine_status;
+    ULONG fault_address;
+    ULONG fault_access;
+};
+
+struct xtajit_memory_params
+{
+    ULONG address;
+    ULONG size;
+    ULONG protection;
+    ULONG old_protection;
+    ULONG operation;
+    ULONG_PTR host;
+};
+
+#endif
