+static inline BOOL use_i386_shadow(void)
+{
+#if defined(__APPLE__) && defined(__aarch64__)
+    return is_wow64() && user_space_wow_limit &&
+           main_image_info.Machine == IMAGE_FILE_MACHINE_I386;
+#else
+    return FALSE;
+#endif
