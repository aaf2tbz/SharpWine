diff --git a/dlls/wow64/wow64_private.h b/dlls/wow64/wow64_private.h
index 2ac3e51f1f..e7e9fa2ce3 100644
--- a/dlls/wow64/wow64_private.h
+++ b/dlls/wow64/wow64_private.h
@@ -39,6 +39,44 @@ extern ULONG_PTR highest_user_address;
 extern ULONG_PTR default_zero_bits;
 extern SYSTEM_DLL_INIT_BLOCK *pLdrSystemDllInitBlock;

+/* Apple Silicon reserves the low 4 GiB in the native Mach-O process.  Keep
+ * 32-bit Windows addresses unchanged in guest state, but dereference them
+ * through the corresponding high host shadow window. */
+static inline void *wow64_guest_ptr( ULONG addr )
+{
+    MEMORY_BASIC_INFORMATION primary_info, alternate_info;
+    void *primary, *alternate;
+    SIZE_T ret_len;
+
+    if (!addr) return NULL;
+    if (current_machine == IMAGE_FILE_MACHINE_I386 && native_machine == IMAGE_FILE_MACHINE_ARM64)
+    {
+        if (addr >= 0x7f000000)
+        {
+            primary = (void *)((ULONG_PTR)0x10000000000ull + addr);
+            alternate = (void *)((ULONG_PTR)0x8000000000ull + addr);
+        }
+        else
+        {
+            primary = (void *)((ULONG_PTR)0x8000000000ull + addr);
+            alternate = (void *)((ULONG_PTR)0x10000000000ull + addr);
+        }
+        if (!NtQueryVirtualMemory( NtCurrentProcess(), primary, MemoryBasicInformation,
+                                   &primary_info, sizeof(primary_info), &ret_len ) &&
+            primary_info.State != MEM_FREE)
+            return primary;
+        if (!NtQueryVirtualMemory( NtCurrentProcess(), alternate, MemoryBasicInformation,
+                                   &alternate_info, sizeof(alternate_info), &ret_len ) &&
+            alternate_info.State != MEM_FREE)
+            return alternate;
+        return primary;
+    }
+    return (void *)(ULONG_PTR)addr;
+}
+
+#undef ULongToPtr
+#define ULongToPtr(addr) wow64_guest_ptr( addr )
+
 extern void     (WINAPI *pBTCpuFlushInstructionCache2)( const void *, SIZE_T );
 extern void     (WINAPI *pBTCpuFlushInstructionCacheHeavy)( const void *, SIZE_T );
 extern NTSTATUS (WINAPI *pBTCpuNotifyMapViewOfSection)( void *, void *, void *, SIZE_T, ULONG, ULONG );
