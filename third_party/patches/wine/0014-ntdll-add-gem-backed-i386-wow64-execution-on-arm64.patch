     sigset_t sigset;
     SIZE_T size;
@@ -4571,9 +4607,18 @@ NTSTATUS virtual_alloc_thread_stack( INITIAL_TEB *stack, ULONG_PTR limit_low, UL
     if (size < 1024 * 1024) size = 1024 * 1024;  /* Xlib needs a large stack */
     size = ROUND_SIZE( 0, size, granularity_mask );

+#if defined(__APPLE__) && defined(__aarch64__)
+    /* The i386 address space is represented above 4 GiB on Apple Silicon.  The
