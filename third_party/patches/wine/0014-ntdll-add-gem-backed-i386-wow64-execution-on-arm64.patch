+
+static inline ULONG_PTR i386_shadow_addr( ULONG_PTR addr )
+{
+    return addr ? 128 * limit_4g + addr : 0;
+}
+
+static inline ULONG_PTR i386_shadow_start(void)
+{
+    return 128 * limit_4g + 0x10000;
+}
