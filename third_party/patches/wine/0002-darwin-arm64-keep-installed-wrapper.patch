From f07539ae5fee5d8e8a9245cf80a88f9157c931a6 Mon Sep 17 00:00:00 2001
From: Avery Felts <averyfelts@users.noreply.github.com>
Date: Sun, 12 Jul 2026 06:09:32 -0600
Subject: [PATCH 2/3] loader: keep the installed Darwin ARM64 wrapper in
 process

Export the preload marker from the installed wrapper and retain the marker in the internal loader. The wrapper already carries the 4 GiB page-zero reservation, so ntdll can initialize in place instead of re-executing an equivalent image. This avoids the observed SIGKILL at execve.
---
 loader/main.c     | 4 ++--
 tools/wine/wine.c | 7 +++++++
 2 files changed, 9 insertions(+), 2 deletions(-)

diff --git a/loader/main.c b/loader/main.c
index f8b113f..279c916 100644
--- a/loader/main.c
+++ b/loader/main.c
@@ -60,7 +60,7 @@ static const struct wine_preload_info preload_info[] =
     { 0, 0 }                                      /* end of list */
 };
 
-const __attribute((visibility("default"))) struct wine_preload_info *wine_main_preload_info = preload_info;
+const __attribute((used, visibility("default"))) struct wine_preload_info *wine_main_preload_info = preload_info;
 
 static void init_reserved_areas(void)
 {
@@ -77,7 +77,7 @@ static void init_reserved_areas(void)
 #else
 
 /* the preloader will set this variable */
-const __attribute((visibility("default"))) struct wine_preload_info *wine_main_preload_info = NULL;
+const __attribute((used, visibility("default"))) struct wine_preload_info *wine_main_preload_info = NULL;
 
 static void init_reserved_areas(void)
 {
diff --git a/tools/wine/wine.c b/tools/wine/wine.c
index 743b3c0..01bac26 100644
--- a/tools/wine/wine.c
+++ b/tools/wine/wine.c
@@ -27,6 +27,13 @@
 static const char *bindir;
 static const char *libdir;
 
+#if defined(__APPLE__) && defined(__aarch64__)
+/* The native arm64 wrapper's 4 GiB __PAGEZERO already reserves the Windows
+ * low-address range. Export the loader marker so ntdll does not re-exec an
+ * equivalent Mach-O image, which Darwin terminates during execve. */
+const __attribute__((used, visibility("default"))) void *wine_main_preload_info;
+#endif
+
 static void *try_dlopen( const char *path, struct strarray *errors )
 {
     void *handle = dlopen( path, RTLD_NOW );
