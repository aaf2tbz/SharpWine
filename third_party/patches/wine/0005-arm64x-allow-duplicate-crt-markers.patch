From 28d53b86c71a6c02c6dd5a551752a9de962ae388 Mon Sep 17 00:00:00 2001
From: MetalSharp Wine Runtime maintainers <maintainers@metalsharp.invalid>
Date: Sun, 12 Jul 2026 08:10:00 -0600
Subject: [PATCH 1/1] winegcc: allow duplicate CRT markers in ARM64X links

LLVM-MinGW's lld rejects the identical CRT boundary and load-config marker
symbols emitted by the ARM64EC and native ARM64 spec objects that Wine
combines for an ARM64X module.  These markers are intentionally emitted by
both architecture views of the same PE image.  Scope the linker relaxation to
ARM64X links only.

Signed-off-by: MetalSharp Wine Runtime maintainers <maintainers@metalsharp.invalid>
---
 tools/winegcc/winegcc.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/tools/winegcc/winegcc.c b/tools/winegcc/winegcc.c
index 20ea512..bd7d5e3 100644
--- a/tools/winegcc/winegcc.c
+++ b/tools/winegcc/winegcc.c
@@ -1345,6 +1345,8 @@ static void build(struct strarray input_files, const char *output)
     strarray_add(&link_args, "-o");
     strarray_add(&link_args, output_file_name);
 
+    if (is_arm64x) strarray_add( &link_args, "-Wl,--allow-multiple-definition" );
+
     STRARRAY_FOR_EACH( dir, &lib_dirs ) strarray_add(&link_args, strmake("-L%s", dir));
 
     strarray_addall( &link_args, spec_objs );
-- 
2.45.2
