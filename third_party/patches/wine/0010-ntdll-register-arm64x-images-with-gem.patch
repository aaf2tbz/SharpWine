+static unsigned int set_named_export_pointers( HMODULE module, const IMAGE_EXPORT_DIRECTORY *exports,
+                                               const char *name, void *value )
+{
+    const WORD *ordinals = (const WORD *)((BYTE *)module + exports->AddressOfNameOrdinals);
+    const DWORD *names = (const DWORD *)((BYTE *)module + exports->AddressOfNames);
+    unsigned int i, count = 0;
+
+    /* ARM64X images may export one data slot for each constituent machine.
+     * Keep every copy synchronized instead of relying on which duplicate a
+     * binary search happens to return. */
+    for (i = 0; i < exports->NumberOfNames; i++)
+    {
+        if (strcmp( (char *)module + names[i], name )) continue;
+        *(void **)find_ordinal_export( module, exports, ordinals[i] ) = value;
+        count++;
+    }
+    return count;
+}
