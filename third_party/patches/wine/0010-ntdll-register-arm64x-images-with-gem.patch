+NTSTATUS gem_virtual_map_metadata(void *base, SIZE_T size, ULONG protection)
+{
+    const SIZE_T page_size = GEM_WINE_GUEST_PAGE_SIZE;
+    SIZE_T offset;
+
+    if (!gem_process || !base || !size || ((SIZE_T)base & (page_size - 1)) ||
+        (size & (page_size - 1))) return STATUS_INVALID_PARAMETER;
+    for (offset = 0; offset < size; offset += page_size)
+    {
+        void *page = (char *)base + offset;
+        enum gem_wine_status status = gem_wine_process_map_identity(
+            gem_process, (uint64_t)(uintptr_t)page, page, page_size, protection );
+
+        if (status == GEM_WINE_CONFLICT)
+            status = gem_wine_process_protect(
+                gem_process, (uint64_t)(uintptr_t)page, page_size, protection, NULL );
+        if (status != GEM_WINE_OK) return gem_status(status);
+    }
+    return STATUS_SUCCESS;
+}
