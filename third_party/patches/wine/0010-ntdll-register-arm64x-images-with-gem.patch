-        /* 16-bit files can't be loaded from the prefix */
-        if (!name[1] || wcscmp( name + wcslen(name) - 2, L"16" )) return status;
+        /* 16-bit files can't be loaded from the prefix.  The ARM64EC
+         * staged runtime is also boot-critical: wineboot and the requested
+         * process can overlap on a brand-new prefix, so any absent fake DLL
