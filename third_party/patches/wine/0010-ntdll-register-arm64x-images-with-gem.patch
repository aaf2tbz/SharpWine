+NTSTATUS gem_register_arm64x(void *args)
+{
+    const struct gem_register_arm64x_params *params = args;
+    struct gem_wine_arm64x_config config = {0};
+    enum gem_wine_status status;
+
+    if (!gem_process || !params || !params->module || !params->image_size)
+        return STATUS_INVALID_PARAMETER;
+    config.version = GEM_WINE_ARM64X_CONFIG_VERSION;
+    config.struct_size = sizeof(config);
+    config.loaded_base = (uint64_t)(uintptr_t)params->module;
+    config.image_size = params->image_size;
+    config.checker_helper = (uint64_t)(uintptr_t)params->checker_helper;
+    config.dispatch_call_helper = (uint64_t)(uintptr_t)params->dispatch_call_helper;
+    config.dispatch_jump_helper = (uint64_t)(uintptr_t)params->dispatch_jump_helper;
+    config.dispatch_ret_helper = (uint64_t)(uintptr_t)params->dispatch_ret_helper;
+    config.flags = GEM_WINE_ARM64X_FLAG_SVC_BOUNDARIES;
+    if (params->flags & GEM_REGISTER_ARM64X_DEFER_ROUTING)
+        config.flags |= GEM_WINE_ARM64X_FLAG_DEFER_ROUTING;
+    TRACE("registering ARM64X module=%p size=%lx checker=%p call=%p jump=%p ret=%p\n",
+          params->module, params->image_size, params->checker_helper,
+          params->dispatch_call_helper, params->dispatch_jump_helper,
+          params->dispatch_ret_helper);
+    status = gem_wine_process_register_arm64x_mapped(gem_process, &config);
+    if (status == GEM_WINE_OK)
+        TRACE("registered ARM64X module=%p size=%lx checker=%p call=%p jump=%p ret=%p\n",
+              params->module, params->image_size, params->checker_helper,
+              params->dispatch_call_helper, params->dispatch_jump_helper,
+              params->dispatch_ret_helper);
+    return gem_status(status);
+}
