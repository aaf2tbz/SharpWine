 NTSTATUS (WINAPI *__wine_unix_call_dispatcher_arm64ec)( unixlib_handle_t, unsigned int, void * ) = __wine_unix_call_arm64ec;
 
+extern void (*__wine_syscall_dispatcher)(void);
+
+void __attribute__((naked)) __wine_gem_syscall_dispatcher(void)
+{
+    asm( "svc #0\n\t"
+         "ret" );
+}
+
+NTSTATUS __attribute__((naked)) __wine_gem_unix_call_dispatcher(
+    unixlib_handle_t handle, unsigned int code, void *args )
+{
+    asm( "svc #0x5749\n\t"
+         "ret" );
+}
+
+/* GEM's checked ARM64EC coordinator consumes these architecturally executed
+ * SVC markers before the following RET. Distinct addresses preserve Wine's
+ * checker/call/jump/return contracts while allowing block JIT execution. */
+static void __attribute__((naked)) gem_arm64x_check_call(void)
+{
+    asm( "svc #0x474d\n\t"
+         "ret" );
+}
+
+static void __attribute__((naked)) gem_arm64x_dispatch_call(void)
+{
+    asm( "svc #0x474d\n\t"
+         "ret" );
+}
+
+static void __attribute__((naked)) gem_arm64x_dispatch_jump(void)
+{
+    asm( "svc #0x474d\n\t"
+         "ret" );
+}
+
+static void __attribute__((naked)) gem_arm64x_dispatch_ret(void)
+{
+    asm( "svc #0x474d\n\t"
+         "ret" );
+}
+
 static void __attribute__((naked)) arm64x_check_call_early(void)
 {
     asm( "mov x11, x9\n\t"
@@ -2113,6 +2194,21 @@ void __attribute__((naked)) RtlUserThreadStart( PRTL_THREAD_START_ROUTINE entry,
 void WINAPI LdrInitializeThunk( CONTEXT *arm_context, ULONG_PTR unk2, ULONG_PTR unk3, ULONG_PTR unk4 )
 {
     ARM64EC_NT_CONTEXT context;
+    const IMAGE_ARM64EC_METADATA *metadata;
+    void *ntdll = NULL;
+
+    /* ARM64EC function pointers name x64 hybrid-exit thunks. The first syscall
+     * runs before normal ARM64X module registration, so resolve the generated
+     * thunks through ntdll's redirection map and enter the real ARM64EC svc
+     * stubs directly. */
+    if (RtlPcToFileHeader( LdrInitializeThunk, &ntdll ) &&
+        (metadata = arm64ec_get_module_metadata( ntdll )))
+    {
+        __wine_syscall_dispatcher = arm64ec_redirect_ptr(
+            ntdll, __wine_gem_syscall_dispatcher, metadata );
+        __wine_unix_call_dispatcher_arm64ec = arm64ec_redirect_ptr(
+            ntdll, __wine_gem_unix_call_dispatcher, metadata );
+    }
 
     if (!__os_arm64x_check_call)
     {
