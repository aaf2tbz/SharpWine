From e5e186beda46c27a53dd12f932b8299db7c9ac44 Mon Sep 17 00:00:00 2001
From: Avery Felts <averyfelts@users.noreply.github.com>
Date: Sun, 12 Jul 2026 06:09:32 -0600
Subject: [PATCH 1/3] loader: preserve the 4 GiB page-zero range on Darwin
 ARM64

Darwin's native ARM64 linker reserves the first 4 GiB by default. Preserve that range explicitly for the Wine loader instead of overriding it with the 4 KiB x86 reservation, and retain the native segment alignment.
---
 configure    | 5 ++++-
 configure.ac | 5 ++++-
 2 files changed, 8 insertions(+), 2 deletions(-)

diff --git a/configure b/configure
index 5cd54ad..e851b9f 100755
--- a/configure
+++ b/configure
@@ -12359,7 +12359,10 @@ case $host_os in
     SYSTEMCONFIGURATION_LIBS="-framework SystemConfiguration"
 
 
-    WINELOADER_LDFLAGS="-Wl,-segalign,0x1000,-pagezero_size,0x1000,-sectcreate,__TEXT,__info_plist,loader/wine_info.plist"
+    case $HOST_ARCH in
+      aarch64) WINELOADER_LDFLAGS="-Wl,-pagezero_size,0x100000000,-sectcreate,__TEXT,__info_plist,loader/wine_info.plist" ;;
+      *) WINELOADER_LDFLAGS="-Wl,-segalign,0x1000,-pagezero_size,0x1000,-sectcreate,__TEXT,__info_plist,loader/wine_info.plist" ;;
+    esac
 
     case $HOST_ARCH in
       i386) wine_use_preloader=yes ;;
diff --git a/configure.ac b/configure.ac
index a8e3bf7..3806578 100644
--- a/configure.ac
+++ b/configure.ac
@@ -989,7 +989,10 @@ case $host_os in
     AC_SUBST(SECURITY_LIBS,"-framework Security -framework CoreFoundation")
     AC_SUBST(SYSTEMCONFIGURATION_LIBS,"-framework SystemConfiguration")
 
-    WINELOADER_LDFLAGS="-Wl,-segalign,0x1000,-pagezero_size,0x1000,-sectcreate,__TEXT,__info_plist,loader/wine_info.plist"
+    case $HOST_ARCH in
+      aarch64) WINELOADER_LDFLAGS="-Wl,-pagezero_size,0x100000000,-sectcreate,__TEXT,__info_plist,loader/wine_info.plist" ;;
+      *) WINELOADER_LDFLAGS="-Wl,-segalign,0x1000,-pagezero_size,0x1000,-sectcreate,__TEXT,__info_plist,loader/wine_info.plist" ;;
+    esac
 
     case $HOST_ARCH in
       i386) wine_use_preloader=yes ;;
