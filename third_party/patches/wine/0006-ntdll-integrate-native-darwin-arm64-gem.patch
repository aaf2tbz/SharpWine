diff --git a/dlls/ntdll/unix/gem.c b/dlls/ntdll/unix/gem.c
new file mode 100644
index 0000000..ae9f336
--- /dev/null
+++ b/dlls/ntdll/unix/gem.c
@@ -0,0 +1,283 @@
+/*
+ * Wine/GEM native lifecycle and checked-memory integration.
+ *
+ * Copyright 2026 Avery Felts
+ *
+ * This library is free software; you can redistribute it and/or
+ * modify it under the terms of the GNU Lesser General Public
+ * License as published by the Free Software Foundation; either
+ * version 2.1 of the License, or (at your option) any later version.
+ *
+ * This library is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+ * Lesser General Public License for more details.
+ */
+
+#if 0
+#pragma makedep unix
+#endif
+
+#include "config.h"
+
+#include <stdint.h>
+#include <stdlib.h>
+#include <string.h>
+
+#include "ntstatus.h"
+#include "winternl.h"
+#include "unix_private.h"
+#include "wine/debug.h"
+
+#if defined(__APPLE__) && defined(__aarch64__)
+
+#include <metalsharp/gem/wine_bridge.h>
+
+WINE_DEFAULT_DEBUG_CHANNEL(gem);
+
+static struct gem_wine_process *gem_process;
+
+static NTSTATUS gem_status(enum gem_wine_status status)
+{
+    switch (status)
+    {
+    case GEM_WINE_OK:               return STATUS_SUCCESS;
+    case GEM_WINE_INVALID_ARGUMENT: return STATUS_INVALID_PARAMETER;
+    case GEM_WINE_NO_MEMORY:        return STATUS_NO_MEMORY;
+    case GEM_WINE_CONFLICT:         return STATUS_CONFLICTING_ADDRESSES;
+    case GEM_WINE_MEMORY_ERROR:     return STATUS_ACCESS_DENIED;
+    default:                        return STATUS_DLL_INIT_FAILED;
+    }
+}
+
+static BOOL executable_protection(ULONG protection)
+{
+    switch (protection & 0xff)
+    {
+    case PAGE_EXECUTE:
+    case PAGE_EXECUTE_READ:
+    case PAGE_EXECUTE_READWRITE:
+    case PAGE_EXECUTE_WRITECOPY:
+        return TRUE;
+    default:
+        return FALSE;
+    }
+}
+
+static void gem_fail(const char *operation, enum gem_wine_status status)
+{
+    ERR("GEM %s failed closed: %s\n", operation, gem_wine_status_name(status));
+    exit(1);
+}
+
+void gem_process_init(void)
+{
+    struct gem_wine_process_config config = {0};
+    enum gem_wine_status status;
+
+    if (gem_process || gem_wine_bridge_abi_version() != GEM_WINE_BRIDGE_ABI_VERSION)
+        gem_fail("ABI validation", GEM_WINE_ENGINE_ERROR);
+    config.version = GEM_WINE_PROCESS_CONFIG_VERSION;
+    config.struct_size = sizeof(config);
+    config.segment_instruction_budget = 100000;
+    config.total_instruction_budget = 1000000;
+    config.max_boundary_callbacks = 4096;
+    config.host_return_sentinel = UINT64_MAX - 15;
+    config.unix_call_dispatcher = (uint64_t)(uintptr_t)__wine_unix_call_dispatcher;
+    if ((status = gem_wine_process_create(&config, &gem_process)) != GEM_WINE_OK)
+        gem_fail("process create", status);
+    TRACE("process created ABI=%u\n", GEM_WINE_BRIDGE_ABI_VERSION);
+}
+
+NTSTATUS gem_thread_init(struct thread_data *data)
+{
+    struct gem_wine_thread_config config = {0};
+    enum gem_wine_status status;
+
+    if (!gem_process || !data || !data->teb || data->gem_thread)
+        return STATUS_INVALID_PARAMETER;
+    config.version = GEM_WINE_THREAD_CONFIG_VERSION;
+    config.struct_size = sizeof(config);
+    config.teb = (uint64_t)(uintptr_t)data->teb;
+    status = gem_wine_thread_create(gem_process, &config, &data->gem_thread);
+    if (status == GEM_WINE_OK) TRACE("thread created teb=%p\n", data->teb);
+    return gem_status(status);
+}
+
+void gem_thread_shutdown(struct thread_data *data)
+{
+    enum gem_wine_status status;
+
+    if (!data || !data->gem_thread) return;
+    status = gem_wine_thread_destroy(data->gem_thread);
+    if (status != GEM_WINE_OK) gem_fail("thread destroy", status);
+    TRACE("thread destroyed teb=%p\n", data->teb);
+    data->gem_thread = NULL;
+}
+
+void gem_process_shutdown(struct thread_data *data)
+{
+    enum gem_wine_status status;
+
+    if (!gem_process) return;
+    gem_thread_shutdown(data);
+    status = gem_wine_process_destroy(gem_process);
+    if (status != GEM_WINE_OK) gem_fail("process destroy", status);
+    gem_process = NULL;
+    TRACE("process destroyed\n");
+}
+
+NTSTATUS gem_virtual_map(void *base, SIZE_T size, ULONG protection, BOOL committed)
+{
+    enum gem_wine_status status;
+
+    if ((uint64_t)(uintptr_t)base == GEM_WINE_KUSER_CANONICAL_ADDRESS &&
+        size == GEM_WINE_GUEST_PAGE_SIZE) return STATUS_SUCCESS;
+    if (!gem_process) return STATUS_DLL_INIT_FAILED;
+    status = gem_wine_process_reserve(gem_process, (uint64_t)(uintptr_t)base, size);
+    if (status != GEM_WINE_OK) return gem_status(status);
+    if (!committed) return STATUS_SUCCESS;
+    status = gem_wine_process_commit_identity(gem_process, (uint64_t)(uintptr_t)base, base, size,
+                                              protection);
+    if (status != GEM_WINE_OK)
+    {
+        enum gem_wine_status rollback =
+            gem_wine_process_release(gem_process, (uint64_t)(uintptr_t)base, size);
+        if (rollback != GEM_WINE_OK) gem_fail("map rollback", rollback);
+        return gem_status(status);
+    }
+    if (executable_protection(protection))
+        return gem_status(gem_wine_process_invalidate_code(
+            gem_process, (uint64_t)(uintptr_t)base, size));
+    return STATUS_SUCCESS;
+}
+
+NTSTATUS gem_virtual_commit(void *base, SIZE_T size, ULONG protection)
+{
+    enum gem_wine_status status;
+
+    if ((uint64_t)(uintptr_t)base == GEM_WINE_KUSER_CANONICAL_ADDRESS &&
+        size == GEM_WINE_GUEST_PAGE_SIZE) return STATUS_SUCCESS;
+    if (!gem_process) return STATUS_DLL_INIT_FAILED;
+    status = gem_wine_process_commit_identity(gem_process, (uint64_t)(uintptr_t)base, base, size,
+                                              protection);
+    if (status == GEM_WINE_OK && executable_protection(protection))
+        status = gem_wine_process_invalidate_code(gem_process, (uint64_t)(uintptr_t)base, size);
+    return gem_status(status);
+}
+
+NTSTATUS gem_virtual_decommit(void *base, SIZE_T size)
+{
+    if (!gem_process) return STATUS_DLL_INIT_FAILED;
+    return gem_status(gem_wine_process_decommit(gem_process, (uint64_t)(uintptr_t)base, size));
+}
+
+NTSTATUS gem_virtual_unmap(void *base, SIZE_T size)
+{
+    if (!gem_process) return STATUS_DLL_INIT_FAILED;
+    return gem_status(gem_wine_process_unmap(gem_process, (uint64_t)(uintptr_t)base, size));
+}
+
+NTSTATUS gem_virtual_release(void *base, SIZE_T size)
+{
+    if ((uint64_t)(uintptr_t)base == GEM_WINE_KUSER_CANONICAL_ADDRESS &&
+        size == GEM_WINE_GUEST_PAGE_SIZE) return STATUS_SUCCESS;
+    if (!gem_process) return STATUS_DLL_INIT_FAILED;
+    return gem_status(gem_wine_process_release(gem_process, (uint64_t)(uintptr_t)base, size));
+}
+
+NTSTATUS gem_virtual_protect(void *base, SIZE_T size, ULONG protection, ULONG *old_protection)
+{
+    enum gem_wine_status status;
+    uint32_t old = 0;
+
+    if (!gem_process) return STATUS_DLL_INIT_FAILED;
+    status = gem_wine_process_protect(gem_process, (uint64_t)(uintptr_t)base, size, protection,
+                                      &old);
+    if (status != GEM_WINE_OK) return gem_status(status);
+    if (old_protection) *old_protection = old;
+    if (executable_protection(old) || executable_protection(protection))
+        status = gem_wine_process_invalidate_code(gem_process, (uint64_t)(uintptr_t)base, size);
+    return gem_status(status);
+}
+
+void gem_virtual_bind_kuser(void *host_page)
+{
+    enum gem_wine_status status;
+
+    if (!gem_process || (status = gem_wine_process_bind_kuser(gem_process, host_page)) != GEM_WINE_OK)
+        gem_fail("KUSER bind", !gem_process ? GEM_WINE_ENGINE_ERROR : status);
+    TRACE("KUSER bound host=%p guest=%p\n", host_page,
+          (void *)(uintptr_t)GEM_WINE_KUSER_SHARED_DATA_ADDRESS);
+}
+
+NTSTATUS gem_virtual_invalidate(const void *base, SIZE_T size)
+{
+    if (!gem_process || !size) return size ? STATUS_DLL_INIT_FAILED : STATUS_SUCCESS;
+    return gem_status(gem_wine_process_invalidate_code(
+        gem_process, (uint64_t)(uintptr_t)base, size));
+}
+
+BOOL gem_lifecycle_probe(void)
+{
+    const char *requested = getenv("METALSHARP_GEM_LIFECYCLE_PROBE");
+    void *base = NULL;
+    SIZE_T size = 2 * GEM_WINE_GUEST_PAGE_SIZE;
+    SIZE_T release_size;
+    ULONG old_protection;
+    NTSTATUS status;
+
+    if (!requested || strcmp( requested, "1" )) return FALSE;
+    if ((status = NtAllocateVirtualMemory( NtCurrentProcess(), &base, 0, &size,
+                                           MEM_RESERVE | MEM_COMMIT, PAGE_READWRITE )))
+        gem_fail("lifecycle probe allocation", GEM_WINE_MEMORY_ERROR);
+    if ((status = NtProtectVirtualMemory( NtCurrentProcess(), &base, &size,
+                                          PAGE_READONLY, &old_protection )) ||
+        old_protection != PAGE_READWRITE)
+    {
+        ERR("lifecycle probe protection status=%08x old=%08x base=%p size=%lx\n",
+            status, old_protection, base, size);
+        gem_fail("lifecycle probe protection", GEM_WINE_MEMORY_ERROR);
+    }
+    if ((status = NtFlushInstructionCache( NtCurrentProcess(), base, size )))
+        gem_fail("lifecycle probe invalidation", GEM_WINE_MEMORY_ERROR);
+    if ((status = NtProtectVirtualMemory( NtCurrentProcess(), &base, &size,
+                                          PAGE_READWRITE | PAGE_GUARD, &old_protection )) ||
+        old_protection != PAGE_READONLY)
+        gem_fail("lifecycle probe guard", GEM_WINE_MEMORY_ERROR);
+    release_size = size;
+    if ((status = NtFreeVirtualMemory( NtCurrentProcess(), &base, &release_size, MEM_DECOMMIT )))
+        gem_fail("lifecycle probe decommit", GEM_WINE_MEMORY_ERROR);
+    if ((status = NtAllocateVirtualMemory( NtCurrentProcess(), &base, 0, &size,
+                                           MEM_COMMIT, PAGE_READWRITE )))
+        gem_fail("lifecycle probe recommit", GEM_WINE_MEMORY_ERROR);
+    release_size = 0;
+    if ((status = NtFreeVirtualMemory( NtCurrentProcess(), &base, &release_size, MEM_RELEASE )))
+        gem_fail("lifecycle probe release", GEM_WINE_MEMORY_ERROR);
+    TRACE("lifecycle probe completed\n");
+    return TRUE;
+}
+
+#else
+
+void gem_process_init(void) {}
+NTSTATUS gem_thread_init(struct thread_data *data) { return STATUS_SUCCESS; }
+void gem_thread_shutdown(struct thread_data *data) {}
+void gem_process_shutdown(struct thread_data *data) {}
+NTSTATUS gem_virtual_map(void *base, SIZE_T size, ULONG protection, BOOL committed)
+{
+    return STATUS_SUCCESS;
+}
+NTSTATUS gem_virtual_commit(void *base, SIZE_T size, ULONG protection) { return STATUS_SUCCESS; }
+NTSTATUS gem_virtual_decommit(void *base, SIZE_T size) { return STATUS_SUCCESS; }
+NTSTATUS gem_virtual_unmap(void *base, SIZE_T size) { return STATUS_SUCCESS; }
+NTSTATUS gem_virtual_release(void *base, SIZE_T size) { return STATUS_SUCCESS; }
+NTSTATUS gem_virtual_protect(void *base, SIZE_T size, ULONG protection, ULONG *old_protection)
+{
+    return STATUS_SUCCESS;
+}
+void gem_virtual_bind_kuser(void *host_page) {}
+NTSTATUS gem_virtual_invalidate(const void *base, SIZE_T size) { return STATUS_SUCCESS; }
+BOOL gem_lifecycle_probe(void) { return FALSE; }
+
+#endif
