+        esac
+        test -f "$with_metalsharp_gem/include/metalsharp/gem/wine_bridge.h" ||
+          as_fn_error $? "MetalSharp GEM Wine bridge header is missing" "$LINENO" 5
+        test -f "$with_metalsharp_gem/lib/libmetalsharp-gem-wine.0.dylib" ||
+          as_fn_error $? "libmetalsharp-gem-wine.0.dylib is missing" "$LINENO" 5
+        gem_file_output=`file "$with_metalsharp_gem/lib/libmetalsharp-gem-wine.0.dylib" 2>/dev/null`
+        case "$gem_file_output" in
+          *Mach-O*arm64*) ;;
+          *) as_fn_error $? "MetalSharp GEM Wine bridge is not native ARM64 Mach-O" "$LINENO" 5 ;;
+        esac
+        case "$gem_file_output" in
+          *x86_64*) as_fn_error $? "MetalSharp GEM Wine bridge contains an x86_64 slice" "$LINENO" 5 ;;
+        esac
+        save_CPPFLAGS=$CPPFLAGS
+        save_LDFLAGS=$LDFLAGS
+        save_LIBS=$LIBS
+        CPPFLAGS="$CPPFLAGS -I$with_metalsharp_gem/include"
+        LDFLAGS="$LDFLAGS -L$with_metalsharp_gem/lib -Wl,-rpath,$with_metalsharp_gem/lib"
+        LIBS="-lmetalsharp-gem-wine $LIBS"
+        { printf '%s\n' "$as_me:${as_lineno-$LINENO}: checking for exact MetalSharp GEM Wine bridge ABI 1" >&5
+printf %s "checking for exact MetalSharp GEM Wine bridge ABI 1... " >&6; }
+        if test "$cross_compiling" = yes
+then :
+  { { printf '%s\n' "$as_me:${as_lineno-$LINENO}: error: in '$ac_pwd':" >&5
+printf '%s\n' "$as_me: error: in '$ac_pwd':" >&2;}
+as_fn_error $? "cannot execute the native MetalSharp GEM ABI probe
+See 'config.log' for more details" "$LINENO" 5; }
+else case e in #(
+  e) cat confdefs.h - <<_ACEOF >conftest.$ac_ext
+/* end confdefs.h.  */
+#include <metalsharp/gem/wine_bridge.h>
+int
+main (void)
+{
+return GEM_WINE_BRIDGE_ABI_VERSION != 1 ||
+                                               gem_wine_bridge_abi_version() != 1;
+  ;
+  return 0;
+}
+_ACEOF
+if ac_fn_c_try_run "$LINENO"
+then :
+  { printf '%s\n' "$as_me:${as_lineno-$LINENO}: result: yes" >&5
+printf '%s\n' "yes" >&6; }
+else case e in #(
+  e) { { printf '%s\n' "$as_me:${as_lineno-$LINENO}: error: in '$ac_pwd':" >&5
+printf '%s\n' "$as_me: error: in '$ac_pwd':" >&2;}
+as_fn_error $? "MetalSharp GEM Wine bridge ABI mismatch
+See 'config.log' for more details" "$LINENO" 5; } ;;
+esac
+fi
+rm -f core *.core core.conftest.* gmon.out bb.out conftest$ac_exeext \
+  conftest.$ac_objext conftest.beam conftest.$ac_ext ;;
+esac
+fi
+
+        CPPFLAGS=$save_CPPFLAGS
+        LDFLAGS=$save_LDFLAGS
+        LIBS=$save_LIBS
+        METALSHARP_GEM_CFLAGS="-I$with_metalsharp_gem/include"
+        METALSHARP_GEM_LIBS="-L$with_metalsharp_gem/lib -Wl,-rpath,@loader_path/../.. -lmetalsharp-gem-wine"
+        ;;
       *) WINELOADER_LDFLAGS="-Wl,-segalign,0x1000,-pagezero_size,0x1000,-sectcreate,__TEXT,__info_plist,loader/wine_info.plist" ;;
     esac
 
@@ -24293,6 +24420,8 @@ TOP_INSTALL_LIB = $TOP_INSTALL_LIB
 TOP_INSTALL_DEV = $TOP_INSTALL_DEV
 WINELOADER_LDFLAGS = $WINELOADER_LDFLAGS
 WINEPRELOADER_LDFLAGS = $WINEPRELOADER_LDFLAGS
