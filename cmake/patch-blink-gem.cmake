if(NOT DEFINED BLINK_SOURCE_DIR OR NOT DEFINED MSWR_SOURCE_DIR)
 message(FATAL_ERROR "required paths missing")
endif()
set(p1 "${MSWR_SOURCE_DIR}/third_party/patches/blink/0001-gem-real-interpreter-embedding.patch")
set(p2 "${MSWR_SOURCE_DIR}/third_party/patches/blink/0002-gem-bounded-jit-embedding.patch")
set(p3 "${MSWR_SOURCE_DIR}/third_party/patches/blink/0003-gem-i386-legacy-mode.patch")
foreach(pair IN ITEMS "${p1};36774371e862c7a44775b19d16b130c23ab0beccf223d755b0321225c7fbfd03" "${p2};797f92651c17b86cce97a5bc73dd88e0c014e4f7c8664b4ee4d4c431a8175c80" "${p3};50499a434838be5620fb86d4a6e214e6a9545eeac0dd059b1f56385a78b6cbeb")
 list(GET pair 0 p)
 list(GET pair 1 expected)
 file(SHA256 "${p}" actual)
 if(NOT actual STREQUAL expected)
  message(FATAL_ERROR "Blink patch hash mismatch: ${p}")
 endif()
endforeach()
foreach(pair IN ITEMS "machine.h;337f3a3a56e560994b269e667be5e84597f5da989bcd94d1ef8519c4a8cc780f" "machine.c;73a32c95fbc191394c116bd2f41ebba464c963718b3785adaca22c5a93e8dc89" "throw.c;5df4b02be0d089b25c6318841cb072c5af9ca1b3e5aa9e11982bdc73ca7e2eed")
 list(GET pair 0 f)
 list(GET pair 1 expected)
 file(SHA256 "${BLINK_SOURCE_DIR}/blink/${f}" actual)
 if(NOT actual STREQUAL expected)
  message(FATAL_ERROR "dirty/unreviewed Blink ${f}")
 endif()
endforeach()
execute_process(COMMAND patch -p1 --batch --forward -i "${p1}" WORKING_DIRECTORY "${BLINK_SOURCE_DIR}" RESULT_VARIABLE rc)
if(NOT rc EQUAL 0)
 message(FATAL_ERROR "Blink interpreter embedding patch failed")
endif()
foreach(pair IN ITEMS "gem_embed.h;a05ed2f546b147960617f7dbf867c62862b6f47571e496e679ce0f2ec93daf24" "gem_embed.c;6c5fff5dd654377289b7f294620763f9a83ba9e27da52fe12afaaf9bf6ecd405" "machine.c;898c8f59110e33d703d95aff35297e9e69fddfde33fadae4da41f5b8c224314f" "jit.h;82b4b0790cc4e4bde0e99a4542531b7352e8102855e5118d5f0a737949662d49" "jit.c;22a35a45b3895236f1f69719fe181a53e83496e71ce816739af058ad052badaf")
 list(GET pair 0 f)
 list(GET pair 1 expected)
 file(SHA256 "${BLINK_SOURCE_DIR}/blink/${f}" actual)
 if(NOT actual STREQUAL expected)
  message(FATAL_ERROR "Blink interpreter baseline mismatch: ${f}")
 endif()
endforeach()
execute_process(COMMAND patch -p1 --batch --forward -i "${p2}" WORKING_DIRECTORY "${BLINK_SOURCE_DIR}" RESULT_VARIABLE rc)
if(NOT rc EQUAL 0)
 message(FATAL_ERROR "Blink bounded JIT embedding patch failed")
endif()
execute_process(COMMAND patch -p1 --batch --forward -i "${p3}" WORKING_DIRECTORY "${BLINK_SOURCE_DIR}" RESULT_VARIABLE rc)
if(NOT rc EQUAL 0)
 message(FATAL_ERROR "Blink i386 legacy-mode patch failed")
endif()
